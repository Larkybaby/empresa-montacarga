---
import type { Montacargas } from '../interfaces/montacargas';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
//import Carrito from '../components/Carrito.astro'
import MontacargasCarrucel from '../components/MontacargasCarrucel.astro';
import CatalogoList from '../components/CatalogoList.astro';
const respuesta = await fetch(new URL('/api/montacargas', Astro.url));
const montacargas: Montacargas[] = await respuesta.json();


---
<Layout>
	<section class="catalogo-hero">
  <div class="catalogo-hero__noise"></div>
  <div class="catalogo-hero__inner">
    <p class="catalogo-hero__eyebrow">// Línea completa 2026</p>
    <h1 class="catalogo-hero__title">Catálogo</h1>
  </div>
  <span class="corner corner--tl"></span>
  <span class="corner corner--br"></span>
</section>
	<MontacargasCarrucel />
	<CatalogoList />
</Layout>
