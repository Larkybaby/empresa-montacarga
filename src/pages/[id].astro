---
import type { Montacargas } from '../interfaces/montacargas';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export async function getStaticPaths() {
  const respuesta = await fetch('http://localhost:4321/api/montacargas');
  const montacargas: Montacargas[] = await respuesta.json();
  return montacargas.map((m) => ({
    params: { id: String(m.id) },
    props: { m },
  }));
}

const { m } = Astro.props;
// Mostrar siempre la imagen principal primero, luego cualquier galería extra.
const galeria: string[] = [m.imagen, ...(m.imagenes ?? [])];
const galeriaUnica: string[] = Array.from(new Set(galeria)).filter(Boolean);
---

<Layout>
  <Header />
  <canvas id="prod-canvas"></canvas>

  <div class="detalle-wrapper">
    <a href="/Catalogo" class="back-button">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M9 2L4 7L9 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Catálogo
    </a>

    <div class="detalle-card">

      <!-- ═══ COLUMNA IZQUIERDA: Visor 360° ═══ -->
      <div class="galeria-col">

        <!-- Miniaturas verticales con flechas -->
        {galeriaUnica.length > 1 && (
          <div class="miniaturas-wrap">
            <button class="miniaturas-arrow" id="arrow-up" aria-label="Subir">
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                <path d="M2 7L5 3L8 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>

            <div class="miniaturas" id="miniaturas-track">
              {galeriaUnica.map((src, i) => (
                <button
                  class={`miniatura ${i === 0 ? 'activa' : ''}`}
                  data-src={src}
                  data-index={i}
                  aria-label={`Ver imagen ${i + 1}`}
                >
                  <img src={src} alt={`${m.modelo} vista ${i + 1}`} />
                </button>
              ))}
            </div>

            <button class="miniaturas-arrow" id="arrow-down" aria-label="Bajar">
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                <path d="M2 3L5 7L8 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        )}

        <!-- Visor 360° -->
        <div class="img-principal-wrap" id="spin-wrap">

          <!-- Todas las imágenes apiladas; JS muestra solo la activa -->
          {galeriaUnica.map((src, i) => (
            <img
              class="spin-frame"
              src={src}
              alt={`${m.modelo} ángulo ${i + 1}`}
              data-spin-index={i}
              draggable="false"
            />
          ))}

          <!-- Badge disponibilidad -->
          <div class="img-badge">
            <span class={`disponible-dot ${m.disponible ? 'verde' : 'rojo'}`}></span>
            {m.disponible ? 'Disponible' : 'No disponible'}
          </div>

          <!-- Badge 360 -->
          <div class="badge-360">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
              <path d="M12 4C8 4 4.5 5.5 2.5 8L1 6v5h5l-2-2c1.5-2 4-3 8-3 4.4 0 8 2.2 8 5s-3.6 5-8 5c-2.5 0-4.7-.8-6.2-2.1L4.2 15.4C6.1 17 8.9 18 12 18c5.5 0 10-3.1 10-7s-4.5-7-10-7z" fill="currentColor"/>
            </svg>
            360°
          </div>

          <!-- Barra de progreso -->
          <div class="spin-progress-wrap">
            <div class="spin-progress-bar" id="spin-progress"></div>
          </div>

          <!-- Botón pausa/play -->
          <button class="spin-toggle" id="spin-toggle" aria-label="Pausar rotación">
            <svg id="icon-pause" width="11" height="11" viewBox="0 0 12 12" fill="none">
              <rect x="2" y="1" width="3" height="10" rx="1" fill="currentColor"/>
              <rect x="7" y="1" width="3" height="10" rx="1" fill="currentColor"/>
            </svg>
            <svg id="icon-play" width="11" height="11" viewBox="0 0 12 12" fill="none" style="display:none">
              <path d="M3 2l7 4-7 4V2z" fill="currentColor"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- ═══ COLUMNA CENTRAL: Info ═══ -->
      <div class="info-col">
        <div class="info-top">
          <span class="tipo-tag">{m.tipo}</span>
          <h1 class="modelo-titulo">{m.modelo}</h1>
          <span class="badge-para">{m.para}</span>
        </div>

        <div class="specs-grid">
          <div class="spec-card">
            <span class="spec-icon">⚡</span>
            <span class="spec-label">Capacidad</span>
            <span class="spec-val">{m.capacidad}</span>
          </div>
          <div class="spec-card">
            <span class="spec-icon">🔧</span>
            <span class="spec-label">Tipo</span>
            <span class="spec-val">{m.tipo}</span>
          </div>
          <div class="spec-card full">
            <span class="spec-icon">📋</span>
            <span class="spec-label">Detalles</span>
            <span class="spec-val detalles-val">{m.detalles}</span>
          </div>
        </div>
      </div>

      <!-- ═══ COLUMNA DERECHA: Acción ═══ -->
      <div class="accion-col">
        <div class="accion-inner">
          <div class="accion-titulo">
            <p class="accion-sub">¿Listo para operar?</p>
            <h2 class="accion-h2">{m.modelo}</h2>
          </div>

          <div class="accion-divider"></div>

          <ul class="ventajas">
            <li>
              <span class="check">✓</span>
              Entrega rápida
            </li>
            <li>
              <span class="check">✓</span>
              Soporte técnico incluido
            </li>
            <li>
              <span class="check">✓</span>
              Garantía de servicio
            </li>
          </ul>

          <button
            class="btn-comprar"
            data-nombre={m.modelo}
          >
            <span>Encargar Ahora</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8H13M9 4L13 8L9 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <p class="accion-nota">Respuesta en menos de 24 hrs vía WhatsApp</p>
        </div>
      </div>

    </div>
  </div>

  <Footer />
</Layout>

<style>
  /* ── Google Fonts ── */
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;600;700;900&display=swap');

  /* ── Variables ── */
  :root {
    --navy:   #0a1628;
    --navy2:  #0e1e38;
    --yellow: #f5a623;
    --yellow2:#d4871a;
    --white:  #f0ece2;
    --steel:  #8a99b3;
    --green:  #4ade80;
    --red:    #f87171;
    --cream:  #f7f5ef;
  }

  /* ── Canvas fondo ── */
  #prod-canvas {
    position: fixed; inset: 0;
    width: 100%; height: 100%;
    z-index: -1; pointer-events: none;
  }

  /* ── Wrapper ── */
  .detalle-wrapper {
    max-width: 1300px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
    font-family: 'DM Sans', sans-serif;
    position: relative; z-index: 1;
  }

  /* ── Back button ── */
  .back-button {
    display: inline-flex; align-items: center; gap: 0.5rem;
    margin-bottom: 2rem;
    padding: 0.5rem 1.1rem;
    background: transparent;
    color: var(--navy2);
    border: 1.5px solid rgba(14,30,56,0.18);
    border-radius: 8px;
    font-size: 0.8rem; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase;
    text-decoration: none;
    transition: all 0.2s;
  }
  .back-button:hover {
    background: var(--navy2);
    color: var(--white);
    border-color: var(--navy2);
  }

  /* ══════════════════════════════════════
     CARD PRINCIPAL (3 columnas)
  ══════════════════════════════════════ */
  .detalle-card {
    display: grid;
    grid-template-columns: 1.4fr 1.3fr 0.85fr;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(10,22,40,0.22);
    animation: cardIn 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  @keyframes cardIn {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0);    }
  }

  /* ══════════════════════════════════════
     COLUMNA IZQUIERDA: Galería
  ══════════════════════════════════════ */
  .galeria-col {
    background: #f0ede4;
    display: flex;
    flex-direction: row;
    gap: 0.75rem;
    padding: 1rem;
    min-width: 0;
    overflow: hidden;
    align-items: stretch;
  }

  .img-principal-wrap {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    background: white;
    flex: 1;
    min-width: 0;
    min-height: 340px;
    box-shadow: 0 4px 20px rgba(10,22,40,0.1);
  }

  /* Mostrar primer frame mientras JS no ha corrido aún */
  .spin-frame:first-child {
    opacity: 1;
  }
  .spin-frame:first-child ~ .spin-frame {
    opacity: 0;
  }
  /* Una vez que JS toma control, .activa maneja la visibilidad */
  .spin-frame.activa {
    opacity: 1 !important;
  }
  .spin-wrap-ready .spin-frame:first-child:not(.activa) {
    opacity: 0;
  }

  .img-principal {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .img-principal:hover { transform: scale(1.04); }

  .img-badge {
    position: absolute; bottom: 0.6rem; left: 0.6rem;
    display: flex; align-items: center; gap: 0.4rem;
    background: rgba(10,22,40,0.75);
    backdrop-filter: blur(8px);
    color: white;
    font-size: 0.72rem; font-weight: 700;
    letter-spacing: 1px; text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
  }
  .disponible-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    display: inline-block;
  }
  .disponible-dot.verde { background: var(--green); box-shadow: 0 0 6px var(--green); }
  .disponible-dot.rojo  { background: var(--red);   box-shadow: 0 0 6px var(--red);   }
  /* ══════════════════════════════════════
     VISOR 360°
  ══════════════════════════════════════ */
  .spin-frame {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: contain;
    padding: 8px;
    box-sizing: border-box;
    opacity: 0;
    transition: opacity 0.12s ease;
    pointer-events: none;
    user-select: none;
    -webkit-user-drag: none;
  }
  .spin-frame.activa { opacity: 1; }

  .badge-360 {
    position: absolute;
    top: 0.6rem; right: 0.6rem;
    display: flex; align-items: center; gap: 0.35rem;
    background: rgba(10,22,40,0.75);
    backdrop-filter: blur(8px);
    color: var(--yellow);
    font-size: 0.68rem; font-weight: 800;
    letter-spacing: 1.5px;
    padding: 0.28rem 0.65rem;
    border-radius: 999px;
  }

  .spin-progress-wrap {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: rgba(10,22,40,0.12);
    border-radius: 0 0 12px 12px;
    overflow: hidden;
  }
  .spin-progress-bar {
    height: 100%;
    background: var(--yellow);
    width: 0%;
    transition: width 0.15s linear;
  }

  .spin-toggle {
    position: absolute;
    bottom: 0.7rem; right: 0.7rem;
    width: 28px; height: 28px;
    background: rgba(10,22,40,0.65);
    backdrop-filter: blur(6px);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 50%;
    color: white;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s, transform 0.15s;
  }
  .spin-toggle:hover {
    background: rgba(10,22,40,0.9);
    transform: scale(1.1);
  }


  /* ══════════════════════════════════════
     MINIATURAS — contenedor con flechas
  ══════════════════════════════════════ */
  .miniaturas-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
    width: 60px;
  }

  /* Flechas: ocultas por defecto, JS las activa si hay más de MAX */
  .miniaturas-arrow {
    width: 60px;
    height: 20px;
    flex-shrink: 0;
    background: rgba(10,22,40,0.07);
    border: 1px solid rgba(10,22,40,0.1);
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--navy2);
    transition: background 0.2s, border-color 0.2s;
    /* ocultas hasta que JS las muestre */
    visibility: hidden;
    pointer-events: none;
  }
  .miniaturas-arrow.visible {
    visibility: visible;
    pointer-events: auto;
  }
  .miniaturas-arrow:hover {
    background: rgba(10,22,40,0.15);
    border-color: rgba(10,22,40,0.2);
  }

  /* El track de miniaturas */
  .miniaturas {
    display: flex;
    flex-direction: column;
    gap: 6px;

    /*
      Altura fija para exactamente 5 miniaturas:
      5 × 60px + 4 × 6px (gaps) = 324px
      Cambia este valor si quieres más o menos visibles.
    */
    max-height: 324px;
    height: 324px;

    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-behavior: smooth;
  }
  .miniaturas::-webkit-scrollbar { display: none; }

  .miniatura {
    width: 60px;
    height: 60px;
    flex-shrink: 0;          /* nunca se encoge */
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid transparent;
    padding: 0;
    cursor: pointer;
    background: white;
    box-sizing: border-box;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .miniatura img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 4px;
    box-sizing: border-box;
    display: block;
  }
  .miniatura:hover  { transform: scale(1.05); border-color: rgba(245,166,35,0.5); }
  .miniatura.activa { border-color: var(--yellow); box-shadow: 0 0 0 1px var(--yellow); }

  /* ══════════════════════════════════════
     COLUMNA CENTRAL: Info
  ══════════════════════════════════════ */
  .info-col {
    background: var(--navy);
    padding: 2rem 1.75rem;
    display: flex; flex-direction: column;
    gap: 1.5rem;
    justify-content: center;
    color: var(--white);
    min-width: 0;
    overflow: hidden;
  }

  .info-top { display: flex; flex-direction: column; gap: 0.6rem; }

  .tipo-tag {
    font-size: 0.65rem; font-weight: 700;
    letter-spacing: 3px; text-transform: uppercase;
    color: var(--yellow);
    opacity: 0.85;
  }

  .modelo-titulo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    letter-spacing: 2px;
    color: var(--white);
    margin: 0; line-height: 1;
  }

  .badge-para {
    display: inline-block;
    background: linear-gradient(90deg, var(--yellow), var(--yellow2));
    color: var(--navy);
    font-size: 0.68rem; font-weight: 800;
    letter-spacing: 2.5px; text-transform: uppercase;
    padding: 0.28rem 0.9rem;
    border-radius: 999px;
    width: fit-content;
  }

  /* Specs grid */
  .specs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem;
  }
  .spec-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(245,166,35,0.1);
    border-radius: 10px;
    padding: 0.9rem 1rem;
    display: flex; flex-direction: column; gap: 0.25rem;
    transition: background 0.2s, border-color 0.2s;
  }
  .spec-card:hover {
    background: rgba(245,166,35,0.06);
    border-color: rgba(245,166,35,0.25);
  }
  .spec-card.full { grid-column: 1 / -1; }

  .spec-icon { font-size: 1.1rem; }
  .spec-label {
    font-size: 0.62rem; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--steel);
  }
  .spec-val {
    font-size: 0.92rem; font-weight: 700;
    color: var(--white);
  }
  .detalles-val {
    font-size: 0.83rem; font-weight: 500;
    color: rgba(240,236,226,0.75);
    line-height: 1.5;
  }

  /* ══════════════════════════════════════
     COLUMNA DERECHA: Acción
  ══════════════════════════════════════ */
  .accion-col {
    background: var(--yellow);
    display: flex; align-items: center; justify-content: center;
  }
  .accion-inner {
    padding: 2rem 1.4rem;
    display: flex; flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    width: 100%;
  }

  .accion-titulo { display: flex; flex-direction: column; gap: 0.2rem; }
  .accion-sub {
    font-size: 0.65rem; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: rgba(10,22,40,0.5);
    margin: 0;
  }
  .accion-h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.8rem; letter-spacing: 2px;
    color: var(--navy); margin: 0; line-height: 1;
  }

  .accion-divider {
    width: 100%; height: 1px;
    background: rgba(10,22,40,0.12);
  }

  .ventajas {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .ventajas li {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.78rem; font-weight: 600;
    color: var(--navy2);
  }
  .check {
    display: inline-flex; align-items: center; justify-content: center;
    width: 18px; height: 18px;
    background: var(--navy);
    color: var(--yellow);
    border-radius: 50%;
    font-size: 0.65rem; font-weight: 900;
    flex-shrink: 0;
  }

  .btn-comprar {
    width: 100%;
    padding: 0.85rem 1.2rem;
    background: var(--navy);
    color: white;
    border: none; border-radius: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem; font-weight: 800;
    letter-spacing: 1.5px; text-transform: uppercase;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 0.5rem;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: 0 4px 16px rgba(10,22,40,0.2);
  }
  .btn-comprar:hover {
    background: #0e2040;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(10,22,40,0.3);
  }
  .btn-comprar:active { transform: translateY(0); }

  .accion-nota {
    font-size: 0.65rem; font-weight: 600;
    color: rgba(10,22,40,0.5);
    text-align: center;
    margin: 0; width: 100%;
    letter-spacing: 0.3px;
  }

  /* ══════════════════════════════════════
     RESPONSIVE
  ══════════════════════════════════════ */
  @media (max-width: 900px) {
    .detalle-card {
      grid-template-columns: 1fr 1fr;
    }
    .accion-col {
      grid-column: 1 / -1;
      border-top: 2px solid rgba(10,22,40,0.08);
    }
    .accion-inner { flex-direction: row; flex-wrap: wrap; align-items: center; }
    .accion-titulo { flex: 1; }
    .ventajas { flex-direction: row; flex-wrap: wrap; gap: 0.75rem; }
    .btn-comprar { width: auto; min-width: 160px; }
  }

  @media (max-width: 600px) {
    .detalle-card { grid-template-columns: 1fr; }
    .accion-inner { flex-direction: column; }
    .btn-comprar { width: 100%; }
  }
</style>

<!-- ── Fondo animado ── -->
<script is:inline>
(function () {
  const canvas = document.getElementById('prod-canvas');
  const ctx = canvas.getContext('2d');
  let W, H, offset = 0, nodes;

  const rand = (a, b) => a + Math.random() * (b - a);

  function resize() {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
    buildNodes();
  }

  function buildNodes() {
    nodes = Array.from({ length: 50 }, () => ({
      x: rand(0, W), y: rand(0, H),
      vx: rand(-0.18, 0.18), vy: rand(-0.18, 0.18),
      r: rand(2, 4),
      yellow: Math.random() < 0.12,
    }));
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = '#f7f5ef';
    ctx.fillRect(0, 0, W, H);

    offset = (offset + 0.3) % 64;
    ctx.save();
    ctx.strokeStyle = 'rgba(14,30,56,0.04)';
    ctx.lineWidth = 1;
    for (let x = -H + offset; x < W + H; x += 64) {
      ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x + H, H); ctx.stroke();
    }
    ctx.restore();

    const MAX = 140;
    for (let i = 0; i < nodes.length; i++) {
      for (let j = i + 1; j < nodes.length; j++) {
        const a = nodes[i], b = nodes[j];
        const dx = a.x - b.x, dy = a.y - b.y;
        const d = Math.sqrt(dx*dx + dy*dy);
        if (d > MAX) continue;
        ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y);
        ctx.strokeStyle = (a.yellow || b.yellow)
          ? `rgba(245,166,35,${(1 - d/MAX) * 0.35})`
          : `rgba(14,30,56,${(1 - d/MAX) * 0.1})`;
        ctx.lineWidth = 0.8; ctx.stroke();
      }
    }

    nodes.forEach(n => {
      n.x += n.vx; n.y += n.vy;
      if (n.x < 0) n.x = W; if (n.x > W) n.x = 0;
      if (n.y < 0) n.y = H; if (n.y > H) n.y = 0;
      const glow = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, n.r * 6);
      glow.addColorStop(0, n.yellow ? 'rgba(245,166,35,0.3)' : 'rgba(14,30,56,0.12)');
      glow.addColorStop(1, 'transparent');
      ctx.beginPath(); ctx.arc(n.x, n.y, n.r * 6, 0, Math.PI * 2);
      ctx.fillStyle = glow; ctx.fill();
      ctx.beginPath(); ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
      ctx.fillStyle = n.yellow ? '#f5a623' : '#1b3f78';
      ctx.globalAlpha = 0.7; ctx.fill(); ctx.globalAlpha = 1;
    });

    requestAnimationFrame(draw);
  }

  window.addEventListener('resize', resize);
  resize();
  requestAnimationFrame(draw);
})();

/* ── Galería / Visor 360° ── */
(function () {
  // Umbral: con >= SPIN_THRESHOLD imágenes se activa modo 360°
  const SPIN_THRESHOLD = 8;

  // Velocidades
  const INTERVALO_SPIN    = 1000;   // ms por frame en modo 360°
  const INTERVALO_GALERIA = 3000;  // ms por imagen en modo galería

  const THUMB_SIZE  = 60;
  const THUMB_GAP   = 6;
  const MAX_VISIBLE = 5;

  const frames     = Array.from(document.querySelectorAll('.spin-frame'));
  const miniaturas = Array.from(document.querySelectorAll('.miniatura'));
  const progress   = document.getElementById('spin-progress');
  const toggleBtn  = document.getElementById('spin-toggle');
  const iconPause  = document.getElementById('icon-pause');
  const iconPlay   = document.getElementById('icon-play');
  const badge360   = document.querySelector('.badge-360');
  const track      = document.getElementById('miniaturas-track');
  const total      = frames.length;

  if (total < 2) {
    // Solo 1 imagen: asegurarse que se muestre
    if (frames[0]) frames[0].classList.add('activa');
    return;
  }

  const modoSpin = total >= SPIN_THRESHOLD;
  const INTERVALO = modoSpin ? INTERVALO_SPIN : INTERVALO_GALERIA;

  // Ocultar badge 360° si no aplica el modo spin
  if (!modoSpin && badge360) badge360.style.display = 'none';

  let indice    = 0;
  let timer     = null;
  let corriendo = true;

  function mostrarFrame(i) {
    indice = ((i % total) + total) % total;

    frames.forEach(f => f.classList.remove('activa'));
    frames[indice].classList.add('activa');

    miniaturas.forEach(b => b.classList.remove('activa'));
    if (miniaturas[indice]) miniaturas[indice].classList.add('activa');

    if (track && miniaturas[indice]) {
      const scrollTarget = indice * (THUMB_SIZE + THUMB_GAP);
      const centrado = scrollTarget - Math.floor(MAX_VISIBLE / 2) * (THUMB_SIZE + THUMB_GAP);
      track.scrollTo({ top: Math.max(0, centrado), behavior: 'smooth' });
    }

    if (progress) {
      progress.style.width = (((indice + 1) / total) * 100) + '%';
    }
  }

  function iniciar() {
    clearInterval(timer);
    timer = setInterval(() => mostrarFrame(indice + 1), INTERVALO);
    corriendo = true;
    if (iconPause) iconPause.style.display = '';
    if (iconPlay)  iconPlay.style.display  = 'none';
  }

  function pausar() {
    clearInterval(timer);
    corriendo = false;
    if (iconPause) iconPause.style.display = 'none';
    if (iconPlay)  iconPlay.style.display  = '';
  }

  if (toggleBtn) {
    toggleBtn.addEventListener('click', () => corriendo ? pausar() : iniciar());
  }

  // En modo galería: pausar al hover sobre la galería
  if (!modoSpin) {
    const galeria = document.querySelector('.galeria-col');
    if (galeria) {
      galeria.addEventListener('mouseenter', pausar);
      galeria.addEventListener('mouseleave', () => { if (!corriendo) iniciar(); });
    }
  }

  miniaturas.forEach((btn, i) => {
    btn.addEventListener('click', () => {
      mostrarFrame(i);
      if (corriendo) { clearInterval(timer); iniciar(); }
      else mostrarFrame(i);
    });
  });

  // FIX timing: esperar a que el DOM esté completamente pintado
  // usando requestAnimationFrame + pequeño delay para Astro SSR
  function arrancar() {
    // Marcar el contenedor como controlado por JS
    const wrap = document.getElementById('spin-wrap');
    if (wrap) wrap.classList.add('spin-wrap-ready');
    mostrarFrame(0);
    iniciar();
  }

  if (document.readyState === 'complete') {
    requestAnimationFrame(arrancar);
  } else {
    window.addEventListener('load', () => requestAnimationFrame(arrancar));
  }
})();

/* ── Flechas de miniaturas ── */
(function () {
  const THUMB_SIZE  = 60;
  const THUMB_GAP   = 6;
  const MAX_VISIBLE = 5;

  const track  = document.getElementById('miniaturas-track');
  const arrowU = document.getElementById('arrow-up');
  const arrowD = document.getElementById('arrow-down');

  if (!track || !arrowU || !arrowD) return;

  const total = track.querySelectorAll('.miniatura').length;

  if (total > MAX_VISIBLE) {
    arrowU.classList.add('visible');
    arrowD.classList.add('visible');
  }

  const step = THUMB_SIZE + THUMB_GAP;
  arrowU.addEventListener('click', () => track.scrollBy({ top: -step, behavior: 'smooth' }));
  arrowD.addEventListener('click', () => track.scrollBy({ top:  step, behavior: 'smooth' }));
})();

