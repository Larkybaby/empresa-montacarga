---
import type { Montacargas } from '../interfaces/montacargas';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export async function getStaticPaths() {
  const respuesta = await fetch('http://localhost:4321/api/montacargas');
  const montacargas: Montacargas[] = await respuesta.json();
  return montacargas.map((m) => ({
    params: { id: String(m.id) },
    props: { m },
  }));
}

const { m } = Astro.props;
// Mostrar siempre la imagen principal primero, luego cualquier galería extra.
const galeria: string[] = [m.imagen, ...(m.imagenes ?? [])];
const galeriaUnica: string[] = Array.from(new Set(galeria)).filter(Boolean);
---

<Layout>
  <Header />
  <canvas id="prod-canvas"></canvas>

  <div class="detalle-wrapper">
    <a href="/Catalogo" class="back-button">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M9 2L4 7L9 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Catálogo
    </a>

    <div class="detalle-card">

      <!-- ═══ COLUMNA IZQUIERDA: Galería ═══ -->
      <div class="galeria-col">
        <!-- Miniaturas verticales a la izquierda -->
        {galeriaUnica.length > 1 && (
          <div class="miniaturas">
            {galeriaUnica.map((src, i) => (
              <button
                class={`miniatura ${i === 0 ? 'activa' : ''}`}
                data-src={src}
                data-index={i}
                aria-label={`Ver imagen ${i + 1}`}
              >
                <img src={src} alt={`${m.modelo} vista ${i + 1}`} />
              </button>
            ))}
          </div>
        )}

        <!-- Imagen principal a la derecha -->
        <div class="img-principal-wrap">
          <img
            id="img-principal"
            src={galeriaUnica[0]}
            alt={m.modelo}
            class="img-principal"
          />
          <div class="img-badge">
            <span class={`disponible-dot ${m.disponible ? 'verde' : 'rojo'}`}></span>
            {m.disponible ? 'Disponible' : 'No disponible'}
          </div>
        </div>
      </div>

      <!-- ═══ COLUMNA CENTRAL: Info ═══ -->
      <div class="info-col">
        <div class="info-top">
          <span class="tipo-tag">{m.tipo}</span>
          <h1 class="modelo-titulo">{m.modelo}</h1>
          <span class="badge-para">{m.para}</span>
        </div>

        <div class="specs-grid">
          <div class="spec-card">
            <span class="spec-icon">⚡</span>
            <span class="spec-label">Capacidad</span>
            <span class="spec-val">{m.capacidad}</span>
          </div>
          <div class="spec-card">
            <span class="spec-icon">🔧</span>
            <span class="spec-label">Tipo</span>
            <span class="spec-val">{m.tipo}</span>
          </div>
          <div class="spec-card full">
            <span class="spec-icon">📋</span>
            <span class="spec-label">Detalles</span>
            <span class="spec-val detalles-val">{m.detalles}</span>
          </div>
        </div>
      </div>

      <!-- ═══ COLUMNA DERECHA: Acción ═══ -->
      <div class="accion-col">
        <div class="accion-inner">
          <div class="accion-titulo">
            <p class="accion-sub">¿Listo para operar?</p>
            <h2 class="accion-h2">{m.modelo}</h2>
          </div>

          <div class="accion-divider"></div>

          <ul class="ventajas">
            <li>
              <span class="check">✓</span>
              Entrega rápida
            </li>
            <li>
              <span class="check">✓</span>
              Soporte técnico incluido
            </li>
            <li>
              <span class="check">✓</span>
              Garantía de servicio
            </li>
          </ul>

          <button
            class="btn-comprar"
            data-nombre={m.modelo}
          >
            <span>Encargar Ahora</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8H13M9 4L13 8L9 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <p class="accion-nota">Respuesta en menos de 24 hrs vía WhatsApp</p>
        </div>
      </div>

    </div>
  </div>

  <Footer />
</Layout>

<style>
  /* ── Google Fonts ── */
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;600;700;900&display=swap');

  /* ── Variables ── */
  :root {
    --navy:   #0a1628;
    --navy2:  #0e1e38;
    --yellow: #f5a623;
    --yellow2:#d4871a;
    --white:  #f0ece2;
    --steel:  #8a99b3;
    --green:  #4ade80;
    --red:    #f87171;
    --cream:  #f7f5ef;
  }

  /* ── Canvas fondo ── */
  #prod-canvas {
    position: fixed; inset: 0;
    width: 100%; height: 100%;
    z-index: -1; pointer-events: none;
  }

  /* ── Wrapper ── */
  .detalle-wrapper {
    max-width: 1300px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
    font-family: 'DM Sans', sans-serif;
    position: relative; z-index: 1;
  }

  /* ── Back button ── */
  .back-button {
    display: inline-flex; align-items: center; gap: 0.5rem;
    margin-bottom: 2rem;
    padding: 0.5rem 1.1rem;
    background: transparent;
    color: var(--navy2);
    border: 1.5px solid rgba(14,30,56,0.18);
    border-radius: 8px;
    font-size: 0.8rem; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase;
    text-decoration: none;
    transition: all 0.2s;
  }
  .back-button:hover {
    background: var(--navy2);
    color: var(--white);
    border-color: var(--navy2);
  }

  /* ══════════════════════════════════════
     CARD PRINCIPAL (3 columnas)
  ══════════════════════════════════════ */
  .detalle-card {
    display: grid;
    grid-template-columns: 1.4fr 1.3fr 0.85fr;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(10,22,40,0.22);
    animation: cardIn 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  @keyframes cardIn {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0);    }
  }

  /* ══════════════════════════════════════
     COLUMNA IZQUIERDA: Galería
  ══════════════════════════════════════ */
  .galeria-col {
    background: #f0ede4;
    display: flex; flex-direction: row;
    gap: 0.75rem;
    padding: 1rem;
    min-width: 0;
    overflow: hidden;
    align-items: stretch;
  }

  .img-principal-wrap {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    background: white;
    flex: 1;
    min-width: 0;
    min-height: 280px;
    box-shadow: 0 4px 20px rgba(10,22,40,0.1);
  }

  .img-principal {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .img-principal:hover { transform: scale(1.04); }

  .img-badge {
    position: absolute; bottom: 0.6rem; left: 0.6rem;
    display: flex; align-items: center; gap: 0.4rem;
    background: rgba(10,22,40,0.75);
    backdrop-filter: blur(8px);
    color: white;
    font-size: 0.72rem; font-weight: 700;
    letter-spacing: 1px; text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
  }
  .disponible-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    display: inline-block;
  }
  .disponible-dot.verde { background: var(--green); box-shadow: 0 0 6px var(--green); }
  .disponible-dot.rojo  { background: var(--red);   box-shadow: 0 0 6px var(--red);   }

  /* Miniaturas */
  .miniaturas {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    flex-shrink: 0;
  }
  .miniaturas::-webkit-scrollbar { display: none; }
  .miniatura {
    width: 56px;
    height: 56px;
    flex-shrink: 0;
    border-radius: 8px; overflow: hidden;
    border: 2px solid transparent;
    padding: 0; cursor: pointer;
    background: white;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .miniatura img {
    width: 100%; height: 100%;
    object-fit: contain; padding: 4px;
  }
  .miniatura:hover  { transform: scale(1.05); border-color: rgba(245,166,35,0.5); }
  .miniatura.activa { border-color: var(--yellow); box-shadow: 0 0 0 1px var(--yellow); }

  /* ══════════════════════════════════════
     COLUMNA CENTRAL: Info
  ══════════════════════════════════════ */
  .info-col {
    background: var(--navy);
    padding: 2rem 1.75rem;
    display: flex; flex-direction: column;
    gap: 1.5rem;
    justify-content: center;
    color: var(--white);
    min-width: 0;
    overflow: hidden;
  }

  .info-top { display: flex; flex-direction: column; gap: 0.6rem; }

  .tipo-tag {
    font-size: 0.65rem; font-weight: 700;
    letter-spacing: 3px; text-transform: uppercase;
    color: var(--yellow);
    opacity: 0.85;
  }

  .modelo-titulo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    letter-spacing: 2px;
    color: var(--white);
    margin: 0; line-height: 1;
  }

  .badge-para {
    display: inline-block;
    background: linear-gradient(90deg, var(--yellow), var(--yellow2));
    color: var(--navy);
    font-size: 0.68rem; font-weight: 800;
    letter-spacing: 2.5px; text-transform: uppercase;
    padding: 0.28rem 0.9rem;
    border-radius: 999px;
    width: fit-content;
  }

  /* Specs grid */
  .specs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem;
  }
  .spec-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(245,166,35,0.1);
    border-radius: 10px;
    padding: 0.9rem 1rem;
    display: flex; flex-direction: column; gap: 0.25rem;
    transition: background 0.2s, border-color 0.2s;
  }
  .spec-card:hover {
    background: rgba(245,166,35,0.06);
    border-color: rgba(245,166,35,0.25);
  }
  .spec-card.full { grid-column: 1 / -1; }

  .spec-icon { font-size: 1.1rem; }
  .spec-label {
    font-size: 0.62rem; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--steel);
  }
  .spec-val {
    font-size: 0.92rem; font-weight: 700;
    color: var(--white);
  }
  .detalles-val {
    font-size: 0.83rem; font-weight: 500;
    color: rgba(240,236,226,0.75);
    line-height: 1.5;
  }

  /* ══════════════════════════════════════
     COLUMNA DERECHA: Acción
  ══════════════════════════════════════ */
  .accion-col {
    background: var(--yellow);
    display: flex; align-items: center; justify-content: center;
  }
  .accion-inner {
    padding: 2rem 1.4rem;
    display: flex; flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    width: 100%;
  }

  .accion-titulo { display: flex; flex-direction: column; gap: 0.2rem; }
  .accion-sub {
    font-size: 0.65rem; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: rgba(10,22,40,0.5);
    margin: 0;
  }
  .accion-h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.8rem; letter-spacing: 2px;
    color: var(--navy); margin: 0; line-height: 1;
  }

  .accion-divider {
    width: 100%; height: 1px;
    background: rgba(10,22,40,0.12);
  }

  .ventajas {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .ventajas li {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.78rem; font-weight: 600;
    color: var(--navy2);
  }
  .check {
    display: inline-flex; align-items: center; justify-content: center;
    width: 18px; height: 18px;
    background: var(--navy);
    color: var(--yellow);
    border-radius: 50%;
    font-size: 0.65rem; font-weight: 900;
    flex-shrink: 0;
  }

  .btn-comprar {
    width: 100%;
    padding: 0.85rem 1.2rem;
    background: var(--navy);
    color: white;
    border: none; border-radius: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem; font-weight: 800;
    letter-spacing: 1.5px; text-transform: uppercase;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 0.5rem;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: 0 4px 16px rgba(10,22,40,0.2);
  }
  .btn-comprar:hover {
    background: #0e2040;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(10,22,40,0.3);
  }
  .btn-comprar:active { transform: translateY(0); }

  .accion-nota {
    font-size: 0.65rem; font-weight: 600;
    color: rgba(10,22,40,0.5);
    text-align: center;
    margin: 0; width: 100%;
    letter-spacing: 0.3px;
  }

  /* ══════════════════════════════════════
     RESPONSIVE
  ══════════════════════════════════════ */
  @media (max-width: 900px) {
    .detalle-card {
      grid-template-columns: 1fr 1fr;
    }
    .accion-col {
      grid-column: 1 / -1;
      border-top: 2px solid rgba(10,22,40,0.08);
    }
    .accion-inner { flex-direction: row; flex-wrap: wrap; align-items: center; }
    .accion-titulo { flex: 1; }
    .ventajas { flex-direction: row; flex-wrap: wrap; gap: 0.75rem; }
    .btn-comprar { width: auto; min-width: 160px; }
  }

  @media (max-width: 600px) {
    .detalle-card { grid-template-columns: 1fr; }
    .accion-inner { flex-direction: column; }
    .btn-comprar { width: 100%; }
  }
</style>

<!-- ── Fondo animado ── -->
<script is:inline>
(function () {
  const canvas = document.getElementById('prod-canvas');
  const ctx = canvas.getContext('2d');
  let W, H, offset = 0, nodes;

  const rand = (a, b) => a + Math.random() * (b - a);

  function resize() {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
    buildNodes();
  }

  function buildNodes() {
    nodes = Array.from({ length: 50 }, () => ({
      x: rand(0, W), y: rand(0, H),
      vx: rand(-0.18, 0.18), vy: rand(-0.18, 0.18),
      r: rand(2, 4),
      yellow: Math.random() < 0.12,
    }));
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = '#f7f5ef';
    ctx.fillRect(0, 0, W, H);

    offset = (offset + 0.3) % 64;
    ctx.save();
    ctx.strokeStyle = 'rgba(14,30,56,0.04)';
    ctx.lineWidth = 1;
    for (let x = -H + offset; x < W + H; x += 64) {
      ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x + H, H); ctx.stroke();
    }
    ctx.restore();

    const MAX = 140;
    for (let i = 0; i < nodes.length; i++) {
      for (let j = i + 1; j < nodes.length; j++) {
        const a = nodes[i], b = nodes[j];
        const dx = a.x - b.x, dy = a.y - b.y;
        const d = Math.sqrt(dx*dx + dy*dy);
        if (d > MAX) continue;
        ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y);
        ctx.strokeStyle = (a.yellow || b.yellow)
          ? `rgba(245,166,35,${(1 - d/MAX) * 0.35})`
          : `rgba(14,30,56,${(1 - d/MAX) * 0.1})`;
        ctx.lineWidth = 0.8; ctx.stroke();
      }
    }

    nodes.forEach(n => {
      n.x += n.vx; n.y += n.vy;
      if (n.x < 0) n.x = W; if (n.x > W) n.x = 0;
      if (n.y < 0) n.y = H; if (n.y > H) n.y = 0;
      const glow = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, n.r * 6);
      glow.addColorStop(0, n.yellow ? 'rgba(245,166,35,0.3)' : 'rgba(14,30,56,0.12)');
      glow.addColorStop(1, 'transparent');
      ctx.beginPath(); ctx.arc(n.x, n.y, n.r * 6, 0, Math.PI * 2);
      ctx.fillStyle = glow; ctx.fill();
      ctx.beginPath(); ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
      ctx.fillStyle = n.yellow ? '#f5a623' : '#1b3f78';
      ctx.globalAlpha = 0.7; ctx.fill(); ctx.globalAlpha = 1;
    });

    requestAnimationFrame(draw);
  }

  window.addEventListener('resize', resize);
  resize();
  requestAnimationFrame(draw);
})();

/* ── Galería interactiva ── */
const imgPrincipal = document.getElementById('img-principal');
document.querySelectorAll('.miniatura').forEach(btn => {
  btn.addEventListener('click', () => {
    const src = btn.dataset.src;
    // transición suave
    imgPrincipal.style.opacity = '0';
    imgPrincipal.style.transform = 'scale(0.96)';
    setTimeout(() => {
      imgPrincipal.src = src;
      imgPrincipal.style.opacity = '1';
      imgPrincipal.style.transform = 'scale(1)';
    }, 180);
    // actualizar miniatura activa
    document.querySelectorAll('.miniatura').forEach(b => b.classList.remove('activa'));
    btn.classList.add('activa');
  });
});
// Añadir transición al img principal
if (imgPrincipal) {
  imgPrincipal.style.transition = 'opacity 0.2s ease, transform 0.2s ease';
}

/* ── WhatsApp ── */
document.querySelectorAll('.btn-comprar').forEach(btn => {
  btn.addEventListener('click', () => {
    const nombre = btn.dataset.nombre || 'Producto';
    const msg = `Hola, me gustaría encargar:\n\n1. ${nombre}\n\n¿Podrían proporcionarme más información sobre el proceso de encargo o renta?`;
    window.open('https://wa.me/524741036525?text=' + encodeURIComponent(msg), '_blank');
  });
});
</script>