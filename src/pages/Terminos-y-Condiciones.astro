---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Terminos from "../components/Terminos.astro";
import Condiciones from "../components/Condiciones.astro";
---

<Layout>
    <Header />
    <img src="https://futuradata.pe/wp-content/uploads/2024/04/terminos-y-condiciones.png" alt="Términos y Condiciones" style="width:100%; border-radius: 20px; margin-top: 30px;">
    <h1>Terminos y Condiciones</h1>
    <Terminos />
    <Condiciones />
    <Footer />
</Layout>

<style is:global>
body {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}
main {
  flex: 1;
}
h1 {
    font-family: 'DM Sans', 'Century Gothic', sans-serif;
    text-align: center;
    margin-top: 40px;
    color: var(--navy);
}
img {
    max-width: 200px;
    margin: 20px auto;
    display: block;
    border-color: black;
    
    border-style: solid;
    border-width: 2px;
}
</style>