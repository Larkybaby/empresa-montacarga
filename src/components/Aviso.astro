---
const empresa = "Sabokar";
const correo = "sabokarrh@gmail.com";
const telefono = "+52 47 41 26 24 88";
const direccion =
  "Rancho los Sauces, SN, Cam a Comanja KM 6, La Sauceda CP 47504 El Tepetate, Jalisco, México";
const actualizacion = "28 de abril de 2026";

const secciones = [
  { numero: "01", titulo: "Identidad del Responsable", tag: "RESP" },
  { numero: "02", titulo: "Datos Recopilados", tag: "DATOS" },
  { numero: "03", titulo: "Finalidades del Tratamiento", tag: "USO" },
  { numero: "04", titulo: "Tecnologías de Rastreo", tag: "COOKIES" },
  { numero: "05", titulo: "Transferencia de Datos", tag: "TRANSF" },
  { numero: "06", titulo: "Derechos ARCO", tag: "ARCO" },
  { numero: "07", titulo: "Medidas de Seguridad", tag: "SEG" },
  { numero: "08", titulo: "Cambios al Aviso", tag: "CAMBIOS" },
  { numero: "09", titulo: "Contacto", tag: "CONTACTO" },
];
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Aviso de Privacidad — {empresa}</title>
    <meta
      name="description"
      content={`Aviso de Privacidad de ${empresa} conforme a la Ley Federal de Protección de Datos Personales en Posesión de los Particulares.`}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,700;0,9..144,900;1,9..144,400&family=Outfit:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="privacy-shell">
      <div class="privacy-progress" aria-hidden="true">
        <span id="readingProgress"></span>
      </div>

      <header class="hero">
        <div class="hero__grid" aria-hidden="true"></div>
        <div class="hero__glow hero__glow--one" aria-hidden="true"></div>
        <div class="hero__glow hero__glow--two" aria-hidden="true"></div>

        <div class="hero__inner">
          <div class="hero__eyebrow">
            <span class="hero__eyebrow-chip">Privacidad</span>
            <span class="hero__eyebrow-meta">LFPDPPP</span>
            <span class="hero__eyebrow-meta">Actualizado: {actualizacion}</span>
          </div>

          <div class="hero__content">
            <div class="hero__copy">
              <p class="hero__pre">Protección de datos personales</p>
              <h1 class="hero__title">
                Aviso de
                <span class="hero__title-accent">Privacidad</span>
              </h1>
              <p class="hero__intro">
                En cumplimiento con la Ley Federal de Protección de Datos Personales en
                Posesión de los Particulares, te informamos de forma clara cómo recopilamos,
                utilizamos, resguardamos y tratamos tus datos personales.
              </p>
            </div>

            <div class="hero__panel">
              <div class="hero__panel-item">
                <span class="hero__panel-label">Empresa</span>
                <strong>{empresa}</strong>
              </div>
              <div class="hero__panel-item">
                <span class="hero__panel-label">Secciones</span>
                <strong>{secciones.length}</strong>
              </div>
              <div class="hero__panel-item">
                <span class="hero__panel-label">Jurisdicción</span>
                <strong>Jalisco</strong>
              </div>
            </div>
          </div>
        </div>

        <div class="hero__watermark" aria-hidden="true">AV</div>
      </header>

      <div class="layout">
        <div class="toc-wrapper">
          <aside class="toc">
            <div class="toc__header">
              <p class="toc__label">Contenido</p>
              <button class="toc__toggle" id="tocToggle" aria-expanded="false" aria-controls="tocNav">
                <span class="toc__toggle-text">Índice de contenido</span>
                <span class="toc__toggle-icon" id="tocIcon">▾</span>
              </button>
            </div>

            <nav class="toc__nav" id="tocNav" aria-label="Índice del aviso de privacidad">
              {secciones.map((s) => (
                <a class="toc__link" href={`#seccion-${s.numero}`}>
                  <span class="toc__num">{s.numero}</span>
                  <span class="toc__body">
                    <span class="toc__titulo">{s.titulo}</span>
                    <span class="toc__tag">{s.tag}</span>
                  </span>
                </a>
              ))}
            </nav>
          </aside>
        </div>

        <main class="content">
          <section class="summary-card" aria-label="Resumen del aviso">
            <div class="summary-card__item">
              <span class="summary-card__label">Documento</span>
              <strong>Aviso de Privacidad</strong>
            </div>
            <div class="summary-card__item">
              <span class="summary-card__label">Responsable</span>
              <strong>{empresa}</strong>
            </div>
            <div class="summary-card__item">
              <span class="summary-card__label">Versión</span>
              <strong>1.0</strong>
            </div>
          </section>

          <section id="seccion-01" class="section">
            <div class="section__header">
              <span class="section__num">01</span>
              <h2 class="section__title">Identidad y Domicilio del Responsable</h2>
              <span class="section__tag">RESP</span>
            </div>
            <div class="section__body">
              <p>
                <strong>{empresa}</strong>, con domicilio en <strong>{direccion}</strong>, es el
                responsable del tratamiento de los datos personales que recabe a través de su sitio
                web y demás medios de contacto.
              </p>
              <p>
                La empresa se compromete a proteger la privacidad de los datos y utilizarlos
                únicamente para los fines descritos en este aviso, en apego a la legislación mexicana.
              </p>

              <div class="contact-grid">
                <div class="contact-card">
                  <span class="contact-card__icon">01</span>
                  <span class="contact-card__label">Correo electrónico</span>
                  <a href={`mailto:${correo}`} class="contact-card__value">{correo}</a>
                </div>
                <div class="contact-card">
                  <span class="contact-card__icon">02</span>
                  <span class="contact-card__label">Teléfono</span>
                  <span class="contact-card__value">{telefono}</span>
                </div>
              </div>
            </div>
          </section>

          <section id="seccion-02" class="section">
            <div class="section__header">
              <span class="section__num">02</span>
              <h2 class="section__title">Datos Personales que se Recopilan</h2>
              <span class="section__tag">DATOS</span>
            </div>
            <div class="section__body">
              <p>
                Los datos que <strong>{empresa}</strong> puede recopilar a través del sitio,
                formularios de contacto, solicitudes de cotización o comunicación directa incluyen:
              </p>
              <ul>
                <li>Nombre completo.</li>
                <li>Nombre de la empresa u organización.</li>
                <li>Dirección de correo electrónico.</li>
                <li>Número de teléfono o celular.</li>
                <li>Dirección o ubicación del proyecto.</li>
                <li>Información relacionada con la solicitud de servicios o productos.</li>
              </ul>
              <div class="callout callout--info">
                Los datos son proporcionados directamente por el usuario. <strong>{empresa}</strong>
                no recopila datos personales sensibles de manera intencional a través del sitio web.
              </div>
            </div>
          </section>

          <section id="seccion-03" class="section">
            <div class="section__header">
              <span class="section__num">03</span>
              <h2 class="section__title">Finalidades del Tratamiento</h2>
              <span class="section__tag">USO</span>
            </div>
            <div class="section__body">
              <p>Los datos personales recopilados serán utilizados para las siguientes finalidades:</p>

              <div class="finalidades-grid">
                <div class="finalidad-card finalidad-card--primary">
                  <div class="finalidad-card__title">
                    <span class="finalidad-card__pill"></span>
                    Primarias
                  </div>
                  <ul>
                    <li>Atender solicitudes de información y contacto.</li>
                    <li>Elaborar cotizaciones de montacargas, renta y servicios técnicos.</li>
                    <li>Brindar asesoría comercial y técnica especializada.</li>
                    <li>Dar seguimiento a solicitudes y contrataciones.</li>
                    <li>Mantener comunicación con clientes y prospectos.</li>
                  </ul>
                </div>

                <div class="finalidad-card finalidad-card--secondary">
                  <div class="finalidad-card__title">
                    <span class="finalidad-card__pill"></span>
                    Secundarias
                  </div>
                  <ul>
                    <li>Envío de información promocional sobre productos o servicios.</li>
                    <li>Realización de encuestas de satisfacción.</li>
                    <li>Análisis interno para mejorar la calidad del servicio.</li>
                  </ul>
                </div>
              </div>

              <div class="callout callout--soft">
                El usuario puede solicitar en cualquier momento que sus datos no sean utilizados
                para finalidades secundarias, sin afectar la prestación de los servicios principales.
              </div>
            </div>
          </section>

          <section id="seccion-04" class="section">
            <div class="section__header">
              <span class="section__num">04</span>
              <h2 class="section__title">Uso de Tecnologías de Rastreo</h2>
              <span class="section__tag">COOKIES</span>
            </div>
            <div class="section__body">
              <p>
                El sitio web puede utilizar <em>cookies</em> u otras herramientas de análisis para
                mejorar la experiencia de navegación del usuario.
              </p>
              <p>Estas tecnologías pueden recopilar:</p>
              <ul>
                <li>Dirección IP del dispositivo de acceso.</li>
                <li>Tipo de navegador y sistema operativo.</li>
                <li>Páginas visitadas y tiempo de navegación dentro del sitio.</li>
                <li>Referencia de origen del acceso al sitio.</li>
              </ul>
              <div class="callout callout--note">
                Esta información se utiliza exclusivamente con fines estadísticos y de mejora del
                sitio. No se vincula a información personal identificable sin consentimiento del usuario.
              </div>
            </div>
          </section>

          <section id="seccion-05" class="section">
            <div class="section__header">
              <span class="section__num">05</span>
              <h2 class="section__title">Transferencia de Datos Personales</h2>
              <span class="section__tag">TRANSF</span>
            </div>
            <div class="section__body">
              <p>
                <strong>{empresa}</strong> no vende, alquila ni comparte los datos personales con
                terceros sin consentimiento previo, salvo en los siguientes casos:
              </p>
              <ul>
                <li>Cuando lo requieran autoridades competentes conforme a la ley.</li>
                <li>Cuando sea necesario para cumplir obligaciones legales o regulatorias.</li>
                <li>Cuando sea indispensable para prestar correctamente los servicios solicitados.</li>
              </ul>
              <div class="callout callout--warning">
                Ante cualquier transferencia que requiera consentimiento expreso, se informará
                previamente al titular y se solicitará su autorización.
              </div>
            </div>
          </section>

          <section id="seccion-06" class="section">
            <div class="section__header">
              <span class="section__num">06</span>
              <h2 class="section__title">Derechos ARCO</h2>
              <span class="section__tag">ARCO</span>
            </div>
            <div class="section__body">
              <p>
                Conforme a la LFPDPPP, el titular de los datos personales puede ejercer en cualquier
                momento los siguientes derechos:
              </p>

              <div class="arco-grid">
                <div class="arco-card">
                  <div class="arco-card__letter">A</div>
                  <div class="arco-card__name">Acceso</div>
                  <p class="arco-card__desc">Conocer qué datos posee la empresa y para qué fines.</p>
                </div>
                <div class="arco-card">
                  <div class="arco-card__letter">R</div>
                  <div class="arco-card__name">Rectificación</div>
                  <p class="arco-card__desc">Corregir datos incorrectos, inexactos o incompletos.</p>
                </div>
                <div class="arco-card">
                  <div class="arco-card__letter">C</div>
                  <div class="arco-card__name">Cancelación</div>
                  <p class="arco-card__desc">Solicitar la eliminación de sus datos del registro.</p>
                </div>
                <div class="arco-card">
                  <div class="arco-card__letter">O</div>
                  <div class="arco-card__name">Oposición</div>
                  <p class="arco-card__desc">Oponerse al uso de sus datos para fines específicos.</p>
                </div>
              </div>

              <p>Envía tu solicitud a <strong>{correo}</strong> incluyendo:</p>
              <ul>
                <li>Nombre completo del titular de los datos.</li>
                <li>Descripción clara y precisa de la solicitud.</li>
                <li>Documento oficial que acredite la identidad del solicitante.</li>
              </ul>
              <div class="callout callout--soft">
                La empresa responderá en un plazo no mayor a <strong>20 días hábiles</strong> a partir
                de la recepción, conforme a lo establecido en la LFPDPPP.
              </div>
            </div>
          </section>

          <section id="seccion-07" class="section">
            <div class="section__header">
              <span class="section__num">07</span>
              <h2 class="section__title">Medidas de Seguridad</h2>
              <span class="section__tag">SEG</span>
            </div>
            <div class="section__body">
              <p>
                <strong>{empresa}</strong> implementa medidas de seguridad administrativas, técnicas
                y físicas para proteger los datos personales contra daño, pérdida, alteración o acceso
                no autorizado.
              </p>
              <div class="callout callout--note">
                Aunque se aplican medidas razonables, ningún sistema es completamente infalible. La empresa
                se compromete a notificar al titular ante cualquier vulneración que afecte significativamente
                sus derechos.
              </div>
            </div>
          </section>

          <section id="seccion-08" class="section">
            <div class="section__header">
              <span class="section__num">08</span>
              <h2 class="section__title">Cambios al Aviso de Privacidad</h2>
              <span class="section__tag">CAMBIOS</span>
            </div>
            <div class="section__body">
              <p>
                <strong>{empresa}</strong> se reserva el derecho de modificar o actualizar el presente
                Aviso en cualquier momento, conforme a cambios en la legislación o en las prácticas internas.
              </p>
              <p>
                Las modificaciones serán publicadas en este sitio con la fecha de actualización. El uso continuado
                del sitio implica la aceptación del aviso vigente.
              </p>
              <div class="callout callout--info">
                Se recomienda revisar periódicamente este aviso para mantenerse informado sobre cómo se protegen
                y utilizan sus datos personales.
              </div>
            </div>
          </section>

          <section id="seccion-09" class="section">
            <div class="section__header">
              <span class="section__num">09</span>
              <h2 class="section__title">Contacto</h2>
              <span class="section__tag">CONTACTO</span>
            </div>
            <div class="section__body">
              <p>
                Para cualquier duda, aclaración o solicitud relacionada con este Aviso de Privacidad
                o el tratamiento de sus datos personales, contáctenos:
              </p>
              <div class="contact-grid contact-grid--three">
                <div class="contact-card">
                  <span class="contact-card__icon">01</span>
                  <span class="contact-card__label">Correo electrónico</span>
                  <a href={`mailto:${correo}`} class="contact-card__value">{correo}</a>
                </div>
                <div class="contact-card">
                  <span class="contact-card__icon">02</span>
                  <span class="contact-card__label">Teléfono</span>
                  <span class="contact-card__value">{telefono}</span>
                </div>
                <div class="contact-card">
                  <span class="contact-card__icon">03</span>
                  <span class="contact-card__label">Dirección</span>
                  <span class="contact-card__value">{direccion}</span>
                </div>
              </div>
            </div>
          </section>
        </main>
      </div>
    </div>

    <script is:inline>
      const toggle = document.getElementById('tocToggle');
      const nav = document.getElementById('tocNav');
      const icon = document.getElementById('tocIcon');
      const links = Array.from(document.querySelectorAll('.toc__link'));
      const sections = document.querySelectorAll('.section');
      const progress = document.getElementById('readingProgress');

      const closeMobileToc = () => {
        if (!nav || !icon || !toggle) return;
        nav.classList.remove('open');
        icon.classList.remove('open');
        toggle.setAttribute('aria-expanded', 'false');
      };

      const setActiveLink = (id) => {
        links.forEach((link) => link.classList.remove('active'));
        const active = document.querySelector(`.toc__link[href="#${id}"]`);
        if (active) active.classList.add('active');
      };

      if (toggle && nav && icon) {
        toggle.addEventListener('click', () => {
          const isOpen = nav.classList.toggle('open');
          icon.classList.toggle('open', isOpen);
          toggle.setAttribute('aria-expanded', String(isOpen));
        });
      }

      links.forEach((link) => {
        link.addEventListener('click', (event) => {
          const href = link.getAttribute('href');
          if (!href || !href.startsWith('#')) return;

          const target = document.querySelector(href);
          if (!target) return;

          if (window.innerWidth < 960) {
            event.preventDefault();
            closeMobileToc();
            window.setTimeout(() => {
              const top = target.getBoundingClientRect().top + window.scrollY - 24;
              window.scrollTo({ top, behavior: 'smooth' });
              history.replaceState(null, '', href);
              setActiveLink(target.id);
            }, 220);
            return;
          }

          setActiveLink(target.id);
        });
      });

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && entry.intersectionRatio > 0) {
            setActiveLink(entry.target.id);
          }
        });
      }, {
        rootMargin: '-18% 0px -58% 0px',
        threshold: 0.12,
      });

      sections.forEach((section) => observer.observe(section));

      const updateProgress = () => {
        if (!progress) return;
        const scrollTop = window.scrollY;
        const height = document.documentElement.scrollHeight - window.innerHeight;
        const ratio = height > 0 ? Math.min(scrollTop / height, 1) : 0;
        progress.style.width = `${ratio * 100}%`;
      };

      updateProgress();
      window.addEventListener('scroll', updateProgress, { passive: true });
      window.addEventListener('resize', updateProgress, { passive: true });
    </script>
  </body>
</html>

<style>
  :root {
    --red: #b31224;
    --red-deep: #7d0f1b;
    --brown: #6f4f37;
    --charcoal: #141112;
    --charcoal-2: #201a1b;
    --panel: rgba(43, 35, 36, 0.88);
    --panel-2: rgba(55, 45, 46, 0.9);
    --white: #ffffff;
    --text: #d7d0ca;
    --text-soft: #a89d95;
    --heading: #f7f3ef;
    --line: rgba(255, 255, 255, 0.09);
    --line-strong: rgba(255, 255, 255, 0.16);
    --red-soft: rgba(179, 18, 36, 0.12);
    --brown-soft: rgba(111, 79, 55, 0.12);
    --shadow: 0 24px 60px rgba(0, 0, 0, 0.24);
    --ff-display: 'Fraunces', serif;
    --ff-body: 'Outfit', sans-serif;
    --r-lg: 24px;
    --r-md: 16px;
    --r-sm: 12px;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    background: var(--charcoal);
    color: var(--text);
    font-family: var(--ff-body);
    font-size: 16px;
    line-height: 1.7;
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100vh;
    overflow-x: clip;
  }

  .privacy-shell {
    min-height: 100vh;
    background:
      radial-gradient(circle at top, rgba(179, 18, 36, 0.18), transparent 24%),
      radial-gradient(circle at bottom right, rgba(111, 79, 55, 0.12), transparent 18%),
      linear-gradient(180deg, #171213 0%, #141112 100%);
    position: relative;
    overflow: hidden;
  }

  .privacy-shell::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    background:
      repeating-linear-gradient(
        60deg,
        rgba(179, 18, 36, 0.08) 0px,
        rgba(179, 18, 36, 0.08) 2px,
        transparent 2px,
        transparent 24px
      );
    opacity: 0.24;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.9), rgba(0, 0, 0, 0.45));
  }

  .privacy-shell::after {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-image: radial-gradient(rgba(255, 255, 255, 0.1) 1px, transparent 1px);
    background-size: 38px 38px;
    opacity: 0.12;
  }

  .privacy-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    z-index: 50;
    background: rgba(20, 17, 18, 0.72);
    backdrop-filter: blur(8px);
  }

  .privacy-progress span {
    display: block;
    width: 0;
    height: 100%;
    background: linear-gradient(90deg, var(--red), #b14554);
    transition: width 0.08s linear;
  }

  .hero {
    position: relative;
    overflow: hidden;
    padding: clamp(4rem, 7vw, 6rem) 1.5rem 3.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(135deg, rgba(31, 25, 26, 0.92), rgba(20, 17, 18, 0.88)),
      radial-gradient(circle at top left, rgba(179, 18, 36, 0.14), transparent 40%);
  }

  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.75), transparent 100%);
    pointer-events: none;
  }

  .hero__glow {
    position: absolute;
    width: 28rem;
    height: 28rem;
    border-radius: 50%;
    filter: blur(72px);
    pointer-events: none;
    opacity: 0.3;
  }

  .hero__glow--one {
    top: -10rem;
    left: -8rem;
    background: rgba(139, 13, 30, 0.16);
  }

  .hero__glow--two {
    right: -10rem;
    bottom: -14rem;
    background: rgba(111, 79, 55, 0.18);
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    width: min(100%, 1160px);
    margin: 0 auto;
  }

  .hero__eyebrow {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    margin-bottom: 1.6rem;
  }

  .hero__eyebrow-chip,
  .hero__eyebrow-meta {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 0.38rem 0.72rem;
    border-radius: 999px;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hero__eyebrow-chip {
    background: var(--red);
