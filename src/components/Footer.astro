<style>
    :root {
    --navy:        #0e1e38;
    --navy-mid:    #1b2f52;
    --yellow:      #efb810;
    --yellow-glow: rgba(245,166,35,0.35);
    --white:       #ffffff;
    --off-white:   #f6f5f0;
    --muted:       #8a97ab;
    --border:      #dde3ec;
    --red:         #8B0D1E;
    --red-mid:     #970014;
    --golden:      #ffffff;
  }
.Footer{
    background: linear-gradient(90deg, var(--red), var(--red-mid));
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    color: white;
    text-align: center;
    margin-top: auto; /* ← empuja el footer hacia abajo */
    width: 100%;
}
.copyright{
    padding-top: 30px;
}
.copyright h4{
    font-family: 'DM Sans', 'Century Gothic', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-muted);
    justify-content: center;
}
.links{
    padding-bottom: 40px;
    padding-top: 20px;

}
.links a{
    font-family: 'DM Sans', 'Century Gothic', sans-serif;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
    position: relative;
    padding: 4px 12px;
    letter-spacing: 0.3px;
}
.links a::after {
    content: '';
    position: absolute;
    width: 0%;
    height: 1.5px;
    left: 50%;
    transform: translateX(-50%);
    bottom: -4px;
    background: var(--golden);
    border-radius: 2px;
    transition: width 0.25s ease;
}
.links a:hover{
    color: var(--white);
}
.links a:hover::after {
    width: 100%;
}
</style>