---
const year = new Date().getFullYear();

const legalLinks = [
  { href: "/Terminos-y-Condiciones", label: "Términos y Condiciones" },
  { href: "/Aviso-de-privacidad", label: "Aviso de Privacidad" },
];
---

<footer class="site-footer">
  <div class="site-footer__glow" aria-hidden="true"></div>

  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <span class="site-footer__eyebrow">Sabokar</span>
      <p class="site-footer__text">
        Soluciones en montacargas, mantenimiento y logística industrial en México.
      </p>
    </div>

    <nav class="site-footer__nav" aria-label="Enlaces legales">
      {legalLinks.map((link) => (
        <a href={link.href} class="site-footer__link">{link.label}</a>
      ))}
    </nav>
  </div>

  <div class="site-footer__bottom">
    <p class="site-footer__copyright">
      &reg;{year} Sabokar. Todos los derechos reservados.
    </p>
  </div>
</footer>

<style>
  :root {
    --footer-red: #8b0d1e;
    --footer-brown: #6f4f37;
    --footer-charcoal: #454545;
    --footer-white: #ffffff;
    --footer-soft: rgba(255, 255, 255, 0.72);
    --footer-line: rgba(255, 255, 255, 0.12);
  }

  .site-footer {
    position: relative;
    overflow: hidden;
    margin-top: auto;
    width: 100%;
    color: var(--footer-white);
    background:
      radial-gradient(circle at top center, rgba(255, 255, 255, 0.08), transparent 28%),
      linear-gradient(135deg, #45070f 0%, var(--footer-red) 44%, var(--footer-brown) 100%);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 -10px 30px rgba(26, 9, 11, 0.18);
  }

  .site-footer__glow {
    position: absolute;
    top: -5rem;
    right: -4rem;
    width: 18rem;
    height: 18rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    filter: blur(55px);
    pointer-events: none;
  }

  .site-footer__inner {
    position: relative;
    z-index: 1;
    width: min(100%, 1180px);
    margin: 0 auto;
    padding: 2rem 1.25rem 1.25rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .site-footer__brand {
    max-width: 28rem;
  }

  .site-footer__eyebrow {
    display: inline-block;
    margin-bottom: 0.45rem;
    font-family: 'DM Sans', 'Century Gothic', sans-serif;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
  }

  .site-footer__text {
    margin: 0;
    font-family: 'DM Sans', 'Century Gothic', sans-serif;
    font-size: 0.97rem;
    line-height: 1.7;
    color: var(--footer-soft);
  }

  .site-footer__nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.6rem;
  }

  .site-footer__link {
    display: inline-flex;
    align-items: center;
    min-height: 42px;
    padding: 0.72rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.06);
    color: var(--footer-white);
    text-decoration: none;
    font-family: 'DM Sans', 'Century Gothic', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    transition:
      transform 0.18s ease,
      background 0.18s ease,
      border-color 0.18s ease,
      color 0.18s ease;
  }

  .site-footer__link:hover,
  .site-footer__link:focus-visible {
    transform: translateY(-1px);
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.24);
    color: var(--footer-white);
    outline: none;
  }

  .site-footer__bottom {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--footer-line);
  }

  .site-footer__copyright {
    width: min(100%, 1180px);
    margin: 0 auto;
    padding: 0.95rem 1.25rem 1.1rem;
    font-family: 'DM Sans', 'Century Gothic', sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.68);
  }

  @media (max-width: 720px) {
    .site-footer__inner {
      flex-direction: column;
      align-items: flex-start;
      padding: 1.6rem 1rem 1rem;
    }

    .site-footer__nav {
      width: 100%;
      justify-content: flex-start;
    }

    .site-footer__link {
      width: 100%;
      justify-content: center;
    }

    .site-footer__copyright {
      padding: 0.9rem 1rem 1rem;
      font-size: 0.79rem;
    }
  }
</style>