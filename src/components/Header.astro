<div class="header">
  <a href="/" class="logo">Logo Empresa</a>

  <!-- Botón hamburguesa -->
  <button class="hamburguesa" id="hamburguesa" aria-label="Abrir menú">
    <span></span>
    <span></span>
    <span></span>
  </button>

  <nav class="nav" id="nav">
    <a href="../Catalogo">Montacargas</a>
    <a href="../Nosotros">Nosotros</a>
    <a href="../Contacto" class="contacto">Contactanos!</a>
  </nav>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap');

  :root {
    --navy-deep: #111e30;
    --navy: #1B263B;
    --navy-mid: #223A5E;
    --yellow: #FFD60A;
    --yellow-dark: #F4B400;
    --text-muted: #a8b4c4;
    --white: #FFFFFF;
  }

  .header {
    display: flex;
    position: sticky;
    justify-content: space-between;
    align-items: center;
    padding: 0 56px;
    height: 100px;
    font-family: 'DM Sans', 'Century Gothic', sans-serif;
    background: linear-gradient(90deg, var(--navy) 0%, var(--navy-mid) 100%);
    box-shadow: 0 1px 0 rgba(255,255,255,0.06), 0 4px 24px rgba(0,0,0,0.2);
    top: 0;
    z-index: 1000;
    transition: height 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
  }

  .header::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--yellow), transparent);
    opacity: 0.4;
    transition: opacity 0.3s ease;
  }
.header {
  /* Quita height fija, usa padding */
  padding: 28px 56px;
  transition: padding 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
  /* Añade esto para que la animación use el GPU */
  will-change: padding, background;
}

.header.scrolled {
  padding: 10px 56px; /* en lugar de height: 60px */
  /* Quita el height: 60px */
}

  .header.scrolled::after { opacity: 0.6; }

  /* LOGO */
  .logo {
    font-size: 1.45rem;
    font-weight: 700;
    color: var(--white);
    text-decoration: none;
    letter-spacing: 0.5px;
    transition: opacity 0.2s ease;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    z-index: 1001;
  }

  .logo::before {
    content: '';
    display: inline-block;
    width: 7px;
    height: 7px;
    background: var(--yellow);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .logo:hover { opacity: 0.8; }

  /* NAV */
  .nav {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav a {
    margin-left: 32px;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
    position: relative;
    padding: 4px 0;
    letter-spacing: 0.3px;
  }

  .nav a::after {
    content: '';
    position: absolute;
    width: 0%;
    height: 1.5px;
    left: 50%;
    transform: translateX(-50%);
    bottom: -4px;
    background: var(--yellow);
    border-radius: 2px;
    transition: width 0.25s ease;
  }

  .nav a:hover { color: var(--white); }
  .nav a:hover::after { width: 100%; }

  .nav a.active { color: var(--white); }
  .nav a.active::after { width: 100%; }

  .nav a.contacto {
    background: var(--yellow);
    color: var(--navy);
    padding: 8px 20px;
    border-radius: 6px;
    margin-left: 40px;
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.3px;
    box-shadow: 0 2px 10px rgba(255,214,10,0.25);
    transition: background 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
  }

  .nav a.contacto:hover {
    background: var(--yellow-dark);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(255,214,10,0.35);
    color: var(--navy);
  }

  .nav a.contacto::after { display: none; }

  /* ── HAMBURGUESA ── */
  .hamburguesa {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    z-index: 1001;
  }

  .hamburguesa span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--white);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  /* Animación X al abrir */
  .hamburguesa.abierto span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hamburguesa.abierto span:nth-child(2) {
    opacity: 0;
  }
  .hamburguesa.abierto span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .header {
      padding: 0 24px;
      height: 70px;
    }

    .hamburguesa {
      display: flex; /* mostrar botón */
    }

    .nav {
      /* menú oculto por defecto */
      position: fixed;
      top: 70px;
      left: 0;
      right: 0;
      background: linear-gradient(180deg, var(--navy) 0%, var(--navy-mid) 100%);
      flex-direction: column;
      align-items: center;
      padding: 2rem 0;
      gap: 0.5rem;
      box-shadow: 0 8px 24px rgba(0,0,0,0.3);
      border-top: 1px solid rgba(255,255,255,0.06);

      /* animación */
      opacity: 0;
      transform: translateY(-10px);
      pointer-events: none;
      transition: opacity 0.25s ease, transform 0.25s ease;
    }

    .nav.abierto {
      opacity: 1;
      transform: translateY(0);
      pointer-events: all;
    }

    .nav a {
      margin-left: 0;
      font-size: 1rem;
      padding: 0.75rem 2rem;
      width: 100%;
      text-align: center;
    }

    .nav a.contacto {
      margin: 0.75rem 2rem 0;
      width: calc(100% - 4rem);
      text-align: center;
    }
  }
  /* Asegura que en PC el nav siempre sea visible sin importar clases */
@media (min-width: 769px) {
  .nav {
    opacity: 1 !important;
    transform: none !important;
    pointer-events: all !important;
    position: static !important;
    flex-direction: row !important;
    padding: 0 !important;
    background: none !important;
    box-shadow: none !important;
  }

  .hamburguesa {
    display: none !important;
  }
}
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var hamburguesa = document.getElementById('hamburguesa');
    var nav = document.getElementById('nav');
    var header = document.querySelector('.header');

    // ── Hamburguesa ──
    hamburguesa.addEventListener('click', function() {
      hamburguesa.classList.toggle('abierto');
      nav.classList.toggle('abierto');
    });

    nav.querySelectorAll('a').forEach(function(link) {
      link.addEventListener('click', function() {
        hamburguesa.classList.remove('abierto');
        nav.classList.remove('abierto');
      });
    });

    // ── Scroll ──
    window.addEventListener('scroll', function() {
      if (window.scrollY > 10) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    });
  });
</script>