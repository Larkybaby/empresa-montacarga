<header class="header" id="header">
  <a href="/" class="logo">
    <div class="logo-icon">
      <img src="/Imagenes/logo-trans.png" alt="Logo Empresa">
    </div>
    <div class="logo-text">
      <span class="logo-name">SABOKAR</span>
      <span class="logo-sub">Montacargas Industriales</span>
    </div>
  </a>

  <button class="hamburguesa" id="hamburguesa" aria-label="Abrir menú">
    <span></span>
    <span></span>
    <span></span>
  </button>

  <nav class="nav" id="nav">
    <a href="../Catalogo">Montacargas</a>
    <a href="../Nosotros">Nosotros</a>
    <a href="../Contacto" class="contacto">Contáctanos</a>
  </nav>
</header>

<style>
    :root {
    --navy:        #0e1e38;
    --navy-mid:    #1b2f52;
    --yellow:      #efb810;
    --yellow-glow: rgba(245,166,35,0.35);
    --white:       #ffffff;
    --off-white:   #f6f5f0;
    --muted:       #8a97ab;
    --border:      #dde3ec;
    --red: #8B0D1E;
    --red-mid: #722a33;
    --golden: #FFD700;
    --gold-muted: #C2A15D;
    --soft-black: #0E0E0E;
  }

  .header {
    display: flex;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    justify-content: space-between;
    align-items: center;
    padding: 0 56px;
    height: 72px;
    font-family: 'DM Sans', 'Century Gothic', sans-serif;
    background: linear-gradient (90deg, var(--cream), #e3cdd0);
    border-bottom: 2px solid var(--cream);
    box-shadow: 0 8px 32px rgba(0,0,0,0.45);
    transition: background 0.3s ease, box-shadow 0.3s ease;
    will-change: transform;
    transform: translateZ(0);
    backface-visibility: hidden;
  }

  /* acento lateral izquierdo */
  .header::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--red);
    opacity: 0.7;
  }

  .header.scrolled {
    background: linear-gradient(90deg, var(--red) 5%, #d70f2a 100%);
    box-shadow: 0 8px 40px rgba(0,0,0,0.6);
  }

  /* ── LOGO ── */
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--white);
    z-index: 1001;
    transition: opacity 0.2s ease;
  }

  .logo:hover { opacity: 0.85; }

  .logo-icon {
    width: 42px;
    height: 42px;
    background: #ffffff;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.2s ease;
    overflow: hidden;
  }

  .logo:hover .logo-icon { transform: scale(1.06); }

  .logo-icon img {
    width: 50px;
    height: 50px;
    object-fit: contain;
    /*filter: brightness(0) invert(1);*/
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .logo-name {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--white);
  }

  .logo-sub {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #cdaeae;
    margin-top: 3px;
  }

  /* ── NAV ── */
  .nav {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav a {
    margin-left: 32px;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--text-muted, #efabab);
    text-decoration: none;
    transition: color 0.2s ease;
    position: relative;
    padding: 4px 0;
    letter-spacing: 0.3px;
  }

  .nav a::after {
    content: '';
    position: absolute;
    width: 0%;
    height: 1.5px;
    left: 50%;
    transform: translateX(-50%);
    bottom: -4px;
    background: var(--cream);
    border-radius: 2px;
    transition: width 0.25s ease;
  }

  .nav a:hover { color: var(--white); }
  .nav a:hover::after { width: 100%; }
  .nav a.active { color: var(--white); }
  .nav a.active::after { width: 100%; }

  .nav a.contacto {
    background: var(--cream);
    color: var(--red);
    padding: 8px 20px;
    border-radius: 6px;
    margin-left: 40px;
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.3px;
    box-shadow: 0 2px 10px rgba(255,214,10,0.25);
    transition: background 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
  }

  .nav a.contacto:hover {
    background: #e75b5b;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(255,214,10,0.35);
    color: var(--white);
  }

  .nav a.contacto::after { display: none; }

  /* ── HAMBURGUESA ── */
  .hamburguesa {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    z-index: 1001;
  }

  .hamburguesa span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--white);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .hamburguesa.abierto span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburguesa.abierto span:nth-child(2) { opacity: 0; }
  .hamburguesa.abierto span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .header {
      padding: 0 24px;
      height: 64px;
    }

    .hamburguesa { display: flex; }

    .nav {
      position: fixed;
      top: 64px;
      left: 0;
      right: 0;
      background: linear-gradient(180deg, var(--red) 0%, var(--red-mid) 100%);
      flex-direction: column;
      align-items: center;
      padding: 2rem 0;
      gap: 0.5rem;
      box-shadow: 0 8px 24px rgba(0,0,0,0.3);
      border-top: 1px solid rgba(245,166,35,0.3);
      opacity: 0;
      transform: translateY(-8px);
      pointer-events: none;
      transition: opacity 0.25s ease, transform 0.25s ease;
    }

    .nav.abierto {
      opacity: 1;
      transform: translateY(0);
      pointer-events: all;
    }

    .nav a {
      margin-left: 0;
      font-size: 1rem;
      padding: 0.75rem 2rem;
      width: 100%;
      text-align: center;
    }

    .nav a.contacto {
      margin: 0.75rem 2rem 0;
      width: calc(100% - 4rem);
      text-align: center;
    }
  }

  @media (min-width: 769px) {
    .nav {
      opacity: 1 !important;
      transform: none !important;
      pointer-events: all !important;
      position: static !important;
      flex-direction: row !important;
      padding: 0 !important;
      background: none !important;
      box-shadow: none !important;
    }
    .hamburguesa { display: none !important; }
  }
</style>

<script is:inline>
  function initHeader() {
    var hamburguesa = document.getElementById('hamburguesa');
    var nav         = document.getElementById('nav');
    var header      = document.getElementById('header');

    if (!hamburguesa || !nav || !header) return;

    hamburguesa.addEventListener('click', function () {
      hamburguesa.classList.toggle('abierto');
      nav.classList.toggle('abierto');
    });

    nav.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', function () {
        hamburguesa.classList.remove('abierto');
        nav.classList.remove('abierto');
      });
    });

    var ticking = false;
    window.addEventListener('scroll', function () {
      if (!ticking) {
        requestAnimationFrame(function () {
          header.classList.toggle('scrolled', window.scrollY > 10);
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    nav.querySelectorAll('a:not(.contacto)').forEach(function (link) {
      if (link.href === window.location.href) {
        link.classList.add('active');
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initHeader);
  document.addEventListener('astro:page-load', initHeader);
</script>