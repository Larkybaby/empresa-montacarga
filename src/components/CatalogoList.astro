---
import type { Montacargas } from '../interfaces/montacargas';
const respuesta = await fetch('http://localhost:4321/api/montacargas');
const montacargas: Montacargas[] = await respuesta.json();
---

<section class="catalogo-lista" id="buscar">

  <!-- Header con buscador -->
  <div class="catalogo-header">
    <div class="header-text">
      <span class="label-top">Nuestro Inventario</span>
      <h1 class="titulo-seccion">Catálogo de <em>Montacargas</em></h1>
    </div>
    <div class="buscador">
      <div class="buscador-inner">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input type="text" placeholder="Buscar por modelo..." id="searchInput" autocomplete="off" />
        <button class="clear-btn" id="clearBtn" aria-label="Limpiar búsqueda">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Filtros -->
  <div class="catalogo-types">
    <button class="filtro activo" data-filtro="todos">
      <span class="filtro-dot"></span>Todos
    </button>
    <button class="filtro" data-filtro="renta">
      <span class="filtro-dot"></span>En Renta
    </button>
    <button class="filtro" data-filtro="venta">
      <span class="filtro-dot"></span>En Venta
    </button>
    <span class="resultado-count" id="resultCount"></span>
  </div>

  <!-- Grid -->
  <div class="catalogo-list" id="catalogoList">
    {montacargas.map((m, i) => (
      <div
        class="catalogo-item"
        data-modelo={m.modelo.toLowerCase()}
        data-para={m.para.toLowerCase()}
        style={`--delay: ${i * 60}ms`}
      >
        <div class="img-wrapper">
          <img src={m.imagen} alt={m.modelo} class="catalogo-img" loading="lazy" />
          <span class={`badge badge--${m.para.toLowerCase()}`}>{m.para}</span>
        </div>
        <div class="card-body">
          <h3 class="card-modelo">{m.modelo}</h3>
          <div class="card-meta">
            <span class="meta-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z"/></svg>
              {m.capacidad}
            </span>
          </div>
          <div class="card-precio">
            <span class="precio-label">Renta desde</span>
            <span class="precio-valor">${Number(m.precio_renta).toLocaleString('es-MX')}<small>/mes</small></span>
          </div>
          <div class="botones">
            <a href={`../${m.id}`} class="btn-ver">
              Ver detalles
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
            </a>
            <button
              class="btn-carrito"
              data-nombre={m.modelo}
              data-precio={String(m.precio_renta)}
              aria-label={`Agregar ${m.modelo} al carrito`}
            >Carrito
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Estado vacío -->
  <div class="empty-state" id="emptyState" style="display:none">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="M8 11h6M11 8v6"/>
    </svg>
    <p>No se encontraron montacargas</p>
    <span>Intenta con otro término o categoría</span>
  </div>

</section>

<style>
  /* ── Variables ─────────────────────────────── */
  .catalogo-lista {
    --navy:       #0b1120;
    --navy-mid:   #111827;
    --navy-card:  #131e2e;
    --yellow:     #f5a623;
    --yellow-dim: rgba(245,166,35,0.15);
    --white:      #f0f4ff;
    --muted:      rgba(240,244,255,0.45);
    --border:     rgba(240,244,255,0.08);
    --radius:     14px;

    padding: 56px 40px 80px;
    background: var(--navy);
    color: var(--white);
    font-family: 'DM Sans', 'Century Gothic', sans-serif;
    min-height: 100vh;
  }

  /* ── Header ────────────────────────────────── */
  .catalogo-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }

  .label-top {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--yellow);
    margin-bottom: 6px;
  }

  .titulo-seccion {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0;
  }

  .titulo-seccion em {
    font-style: normal;
    color: var(--yellow);
  }

  /* ── Buscador ──────────────────────────────── */
  .buscador {
    flex: 0 0 320px;
  }

  .buscador-inner {
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-icon {
    position: absolute;
    left: 14px;
    width: 18px;
    height: 18px;
    color: var(--muted);
    pointer-events: none;
    transition: color 0.2s;
  }

  .buscador-inner:focus-within .search-icon {
    color: var(--yellow);
  }

  .buscador input {
    width: 600px;
    padding: 12px 44px;
    border-radius: 10px;
    border: 1.5px solid var(--border);
    background: rgba(255,255,255,0.05);
    color: var(--white);
    font-size: 0.92rem;
    font-family: inherit;
    transition: border-color 0.25s, background 0.25s, box-shadow 0.25s;
  }

  .buscador input::placeholder { color: var(--muted); }

  .buscador input:focus {
    outline: none;
    border-color: var(--yellow);
    background: rgba(245,166,35,0.06);
    box-shadow: 0 0 0 3px rgba(245,166,35,0.12);
  }

  .clear-btn {
    position: absolute;
    right: 10px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--muted);
    display: none;
    padding: 4px;
    border-radius: 4px;
    transition: color 0.2s;
  }
  .clear-btn svg { width: 16px; height: 16px; display: block; }
  .clear-btn:hover { color: var(--white); }
  .clear-btn.visible { display: flex; }

  /* ── Filtros ───────────────────────────────── */
  .catalogo-types {
    display: flex;
    gap: 8px;
    margin-bottom: 32px;
    align-items: center;
    flex-wrap: wrap;
  }

  .filtro {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 18px;
    border-radius: 100px;
    border: 1.5px solid var(--border);
    background: transparent;
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.22s ease;
  }

  .filtro-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.5;
    transition: opacity 0.2s;
  }

  .filtro:hover {
    color: var(--white);
    border-color: rgba(240,244,255,0.2);
  }

  .filtro.activo {
    background: var(--yellow-dim);
    border-color: var(--yellow);
    color: var(--yellow);
  }
  .filtro.activo .filtro-dot { opacity: 1; }

  .resultado-count {
    margin-left: auto;
    font-size: 0.8rem;
    color: var(--muted);
  }

  /* ── Grid ──────────────────────────────────── */
  .catalogo-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 20px;
  }

  /* ── Card ──────────────────────────────────── */
  .catalogo-item {
    background: var(--navy-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s cubic-bezier(.22,.68,0,1.2), box-shadow 0.3s ease, border-color 0.3s ease;
    animation: fadeUp 0.5s ease both;
    animation-delay: var(--delay, 0ms);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .catalogo-item:hover {
    transform: translateY(-6px);
    border-color: rgba(245,166,35,0.3);
    box-shadow: 0 16px 40px rgba(0,0,0,0.4), 0 0 0 1px rgba(245,166,35,0.1);
  }

  .catalogo-item.oculto { display: none; }

  /* Imagen */
  .img-wrapper {
    position: relative;
    overflow: hidden;
  }

  .catalogo-img {
    width: 100%;
    height: 175px;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
    background: #1a2640;
  }

  .catalogo-item:hover .catalogo-img {
    transform: scale(1.05);
  }

  .badge {
    position: absolute;
    top: 10px;
    right: 10px;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 100px;
    backdrop-filter: blur(8px);
  }

  .badge--renta {
    background: rgba(245,166,35,0.9);
    color: #0b1120;
  }

  .badge--venta {
    background: rgba(52,211,153,0.9);
    color: #0b1120;
  }

  /* Body */
  .card-body {
    padding: 18px 18px 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 10px;
  }

  .card-modelo {
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
    color: var(--white);
    line-height: 1.25;
  }

  .card-meta {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.78rem;
    color: var(--muted);
  }

  .meta-item svg { width: 13px; height: 13px; flex-shrink: 0; }

  /* Precio */
  .card-precio {
    margin-top: auto;
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }

  .precio-label {
    display: block;
    font-size: 0.7rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 2px;
  }

  .precio-valor {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--yellow);
    line-height: 1;
  }

  .precio-valor small {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--muted);
    margin-left: 3px;
  }

  /* Botones */
  .botones {
    display: flex;
    gap: 8px;
    margin-top: 14px;
  }

  .btn-ver {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 3px 14px;
    background: var(--yellow);
    color: var(--navy);
    border: none;
    border-radius: 8px;
    font-size: 0.83rem;
    font-weight: 700;
    font-family: inherit;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-ver svg { width: 15px; height: 15px; flex-shrink: 0; }
  .btn-ver:hover { background: #ffc04d; }
  .btn-ver:active { transform: scale(0.97); }

  .btn-carrito {
    width: 95px;
    height: 40px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    color: var(--yellow);
    border: 1.5px solid var(--yellow);
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-carrito svg { width: 17px; height: 17px; }
  .btn-carrito:hover { background: var(--yellow-dim); }
  .btn-carrito:active { transform: scale(0.93); }

  /* Added to cart feedback */
  .btn-carrito.added {
    background: var(--yellow);
    color: var(--navy);
    animation: pop 0.3s cubic-bezier(.22,.68,0,1.5);
  }

  @keyframes pop {
    0%   { transform: scale(1); }
    50%  { transform: scale(1.2); }
    100% { transform: scale(1); }
  }

  /* ── Empty state ───────────────────────────── */
  .empty-state {
    text-align: center;
    padding: 80px 20px;
    color: var(--muted);
  }
  .empty-state svg {
    width: 56px; height: 56px;
    margin: 0 auto 16px;
    display: block;
    stroke: var(--muted);
  }
  .empty-state p {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 6px;
    color: rgba(240,244,255,0.7);
  }
  .empty-state span { font-size: 0.85rem; }

  /* ── Responsive ────────────────────────────── */
  @media (max-width: 640px) {
    .catalogo-lista { padding: 32px 20px 60px; }
    .catalogo-header { flex-direction: column; align-items: flex-start; }
    .buscador { flex: 1 1 100%; }
    .catalogo-list { grid-template-columns: 1fr 1fr; gap: 14px; }
  }

  @media (max-width: 420px) {
    .catalogo-list { grid-template-columns: 1fr; }
  }
</style>

<script>
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const clearBtn    = document.getElementById('clearBtn') as HTMLButtonElement;
  const filtros     = document.querySelectorAll<HTMLElement>('.filtro');
  const items       = document.querySelectorAll<HTMLElement>('.catalogo-item');
  const emptyState  = document.getElementById('emptyState') as HTMLElement;
  const resultCount = document.getElementById('resultCount') as HTMLElement;

  let filtroActual = 'todos';

  // ── Filtrar ───────────────────────────────────
  function filtrar() {
    const busqueda = searchInput.value.toLowerCase().trim();
    let visibles = 0;

    items.forEach((item) => {
      const modelo = item.dataset.modelo ?? '';
      const para   = item.dataset.para   ?? '';

      const coincideBusqueda = modelo.includes(busqueda);
      const coincideFiltro   = filtroActual === 'todos' || para === filtroActual;

      if (coincideBusqueda && coincideFiltro) {
        item.classList.remove('oculto');
        visibles++;
      } else {
        item.classList.add('oculto');
      }
    });

    // Mostrar / ocultar empty state
    emptyState.style.display = visibles === 0 ? 'block' : 'none';

    // Contador
    resultCount.textContent = visibles === items.length
      ? ''
      : `${visibles} resultado${visibles !== 1 ? 's' : ''}`;

    // Botón limpiar
    clearBtn.classList.toggle('visible', busqueda.length > 0);
  }

  // ── Buscador ──────────────────────────────────
  searchInput.addEventListener('input', filtrar);

  clearBtn.addEventListener('click', () => {
    searchInput.value = '';
    searchInput.focus();
    filtrar();
  });

  // ── Filtros de categoría ──────────────────────
  filtros.forEach((filtro) => {
    filtro.addEventListener('click', () => {
      filtros.forEach((f) => f.classList.remove('activo'));
      filtro.classList.add('activo');
      filtroActual = filtro.dataset.filtro ?? 'todos';
      filtrar();
    });
  });

  // ── Carrito: feedback visual ──────────────────
  document.querySelectorAll<HTMLButtonElement>('.btn-carrito').forEach((btn) => {
    btn.addEventListener('click', () => {
      btn.classList.add('added');
      setTimeout(() => btn.classList.remove('added'), 600);
    });
  });

  // Inicializar contador
  filtrar();
</script>