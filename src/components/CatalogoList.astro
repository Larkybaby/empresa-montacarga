---
import type { Montacargas } from '../interfaces/montacargas';
const respuesta = await fetch('http://localhost:4321/api/montacargas');
const montacargas: Montacargas[] = await respuesta.json();
---

<section class="catalogo-lista" id="buscar">

  <!-- Header con buscador -->
  <div class="catalogo-header">
    <div class="header-text">
      <span class="label-top">Nuestro Inventario</span>
      <h1 class="titulo-seccion">Catálogo de <em>Montacargas</em></h1>
    </div>
    <div class="buscador">
      <div class="buscador-inner">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input type="text" placeholder="Buscar por modelo..." id="searchInput" autocomplete="off" />
        <button class="clear-btn" id="clearBtn" aria-label="Limpiar búsqueda">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Filtros -->
  <div class="catalogo-types">
    <button class="filtro activo" data-filtro="todos">
      <span class="filtro-dot"></span>Todos
    </button>
    <button class="filtro" data-filtro="renta">
      <span class="filtro-dot"></span>En Renta
    </button>
    <button class="filtro" data-filtro="venta">
      <span class="filtro-dot"></span>En Venta
    </button>
    <span class="resultado-count" id="resultCount"></span>
  </div>

  <!-- Grid -->
  <div class="catalogo-list" id="catalogoList">
    {montacargas.map((m, i) => (
      <div
        class="catalogo-item"
        data-modelo={m.modelo.toLowerCase()}
        data-para={m.para.toLowerCase()}
        style={`--delay: ${i * 60}ms`}
      >
        <div class="img-wrapper">
          <img src={m.imagen} alt={m.modelo} class="catalogo-img" loading="lazy" />
          <span class={`badge badge--${m.para.toLowerCase()}`}>{m.para}</span>
        </div>
        <div class="card-body">
          <h3 class="card-modelo">{m.modelo}</h3>
          <div class="card-meta">
            <span class="meta-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z"/></svg>
              {m.capacidad}
            </span>
          </div>
          <div class="botones">
            <a href={`../${m.id}`} class="btn-ver">
              Ver detalles
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
            </a>
            <a
              class="btn-whatsapp"
              href={`https://wa.me/524741036525?text=${encodeURIComponent(`Hola, estoy interesado en el modelo ${m.modelo}`)}`}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Contactar por WhatsApp ${m.modelo}`}
            >
              <!-- Ícono WhatsApp SVG oficial -->
              <svg class="wa-icon" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              <span>Contactar</span>
            </a>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Estado vacío -->
  <div class="empty-state" id="emptyState" style="display:none">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="M8 11h6M11 8v6"/>
    </svg>
    <p>No se encontraron montacargas</p>
    <span>Intenta con otro término o categoría</span>
  </div>

</section>

<style>
  /* ── Variables ─────────────────────────────── */
  .catalogo-lista {
    --navy:       #0b1120;
    --navy-mid:   #111827;
    --navy-card:  #131e2e;
    --yellow:     #f5a623;
    --yellow-dim: rgba(245,166,35,0.15);
    --white:      #f0f4ff;
    --muted:      rgba(240,244,255,0.45);
    --border:     rgba(240,244,255,0.08);
    --radius:     14px;

    padding: 56px 40px 80px;
    background: var(--navy);
    color: var(--white);
    font-family: 'DM Sans', 'Century Gothic', sans-serif;
    min-height: 100vh;
  }

  /* ── Header ────────────────────────────────── */
  .catalogo-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }

  .label-top {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--yellow);
    margin-bottom: 6px;
  }

  .titulo-seccion {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0;
  }

  .titulo-seccion em {
    font-style: normal;
    color: var(--yellow);
  }

  /* ── Buscador ──────────────────────────────── */
  .buscador { flex: 0 0 320px; }

  .buscador-inner {
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-icon {
    position: absolute;
    left: 14px;
    width: 18px; height: 18px;
    color: var(--muted);
    pointer-events: none;
    transition: color 0.2s;
  }

  .buscador-inner:focus-within .search-icon { color: var(--yellow); }

  .buscador input {
    padding: 12px 44px;
    border-radius: 10px;
    border: 1.5px solid var(--border);
    background: rgba(255,255,255,0.05);
    color: var(--white);
    font-size: 0.92rem;
    font-family: inherit;
    transition: border-color 0.25s, background 0.25s, box-shadow 0.25s;
    width: 100%; /* ← cámbialo a width: 100% */
}
  

  .buscador input::placeholder { color: var(--muted); }

  .buscador input:focus {
    outline: none;
    border-color: var(--yellow);
    background: rgba(245,166,35,0.06);
    box-shadow: 0 0 0 3px rgba(245,166,35,0.12);
  }

  .clear-btn {
    position: absolute;
    right: 10px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--muted);
    display: none;
    padding: 4px;
    border-radius: 4px;
    transition: color 0.2s;
  }
  .clear-btn svg { width: 16px; height: 16px; display: block; }
  .clear-btn:hover { color: var(--white); }
  .clear-btn.visible { display: flex; }

  /* ── Filtros ───────────────────────────────── */
  .catalogo-types {
    display: flex;
    gap: 8px;
    margin-bottom: 32px;
    align-items: center;
    flex-wrap: wrap;
  }

  .filtro {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 18px;
    border-radius: 100px;
    border: 1.5px solid var(--border);
    background: transparent;
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.22s ease;
  }

  .filtro-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.5;
    transition: opacity 0.2s;
  }

  .filtro:hover { color: var(--white); border-color: rgba(240,244,255,0.2); }
  .filtro.activo { background: var(--yellow-dim); border-color: var(--yellow); color: var(--yellow); }
  .filtro.activo .filtro-dot { opacity: 1; }

  .resultado-count {
    margin-left: auto;
    font-size: 0.8rem;
    color: var(--muted);
  }

  /* ── Grid ──────────────────────────────────── */
  .catalogo-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 20px;
  }

  /* ── Card ──────────────────────────────────── */
  .catalogo-item {
    background: var(--navy-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s cubic-bezier(.22,.68,0,1.2), box-shadow 0.3s ease, border-color 0.3s ease;
    animation: fadeUp 0.5s ease both;
    animation-delay: var(--delay, 0ms);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .catalogo-item:hover {
    transform: translateY(-6px);
    border-color: rgba(245,166,35,0.3);
    box-shadow: 0 16px 40px rgba(0,0,0,0.4), 0 0 0 1px rgba(245,166,35,0.1);
  }

  .catalogo-item.oculto { display: none; }

  /* Imagen */
  .img-wrapper {
    position: relative;
    overflow: hidden;
  }

  .catalogo-img {
    width: 100%;
    height: 175px;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
    background: #1a2640;
  }

  .catalogo-item:hover .catalogo-img { transform: scale(1.05); }

  .badge {
    position: absolute;
    top: 10px; right: 10px;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 100px;
    backdrop-filter: blur(8px);
  }

  .badge--renta { background: rgba(245,166,35,0.9); color: #0b1120; }
  .badge--venta { background: rgba(52,211,153,0.9); color: #0b1120; }

  /* Body */
  .card-body {
    padding: 18px 18px 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 10px;
  }

  .card-modelo {
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
    color: var(--white);
    line-height: 1.25;
  }

  .card-meta { display: flex; gap: 10px; flex-wrap: wrap; }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.78rem;
    color: var(--muted);
  }
  .meta-item svg { width: 13px; height: 13px; flex-shrink: 0; }

  /* ── Botones ───────────────────────────────── */
  .botones {
    display: flex;
    gap: 8px;
    margin-top: auto;
    padding-top: 14px;
  }

  .btn-ver {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 10px 14px;
    background: var(--yellow);
    color: var(--navy);
    border: none;
    border-radius: 8px;
    font-size: 0.83rem;
    font-weight: 700;
    font-family: inherit;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-ver svg { width: 15px; height: 15px; flex-shrink: 0; }
  .btn-ver:hover { background: #ffc04d; }
  .btn-ver:active { transform: scale(0.97); }

  /* ── WhatsApp button — nuevo diseño ─────────── */
  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 10px 14px;
    background: #25d366;
    color: #fff;
    border: none;
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.83rem;
    font-weight: 700;
    font-family: inherit;
    white-space: nowrap;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: 0 2px 10px rgba(37,211,102,0.25);
  }
  .btn-whatsapp .wa-icon {
    width: 16px; height: 16px;
    flex-shrink: 0;
    fill: #fff;
  }
  .btn-whatsapp:hover {
    background: #1ebe5d;
    box-shadow: 0 4px 16px rgba(37,211,102,0.4);
    transform: translateY(-1px);
  }
  .btn-whatsapp:active { transform: scale(0.95); }

  /* ── Empty state ───────────────────────────── */
  .empty-state {
    text-align: center;
    padding: 80px 20px;
    color: var(--muted);
  }
  .empty-state svg {
    width: 56px; height: 56px;
    margin: 0 auto 16px;
    display: block;
    stroke: var(--muted);
  }
  .empty-state p {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 6px;
    color: rgba(240,244,255,0.7);
  }
  .empty-state span { font-size: 0.85rem; }

  /* ── Responsive ────────────────────────────── */
  @media (max-width: 640px) {
    .catalogo-lista { padding: 32px 20px 60px; }
    .catalogo-header { flex-direction: column; align-items: flex-start; }
    .buscador { flex: 1 1 100%; }
    .buscador input { width: 100%; }
    .catalogo-list { grid-template-columns: 1fr 1fr; gap: 14px; }
  }

  @media (max-width: 420px) {
    .catalogo-list { grid-template-columns: 1fr; }
    .buscador input { width: 100%; }
  }
</style>

<script>
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const clearBtn    = document.getElementById('clearBtn') as HTMLButtonElement;
  const filtros     = document.querySelectorAll<HTMLElement>('.filtro');
  const items       = document.querySelectorAll<HTMLElement>('.catalogo-item');
  const emptyState  = document.getElementById('emptyState') as HTMLElement;
  const resultCount = document.getElementById('resultCount') as HTMLElement;

  let filtroActual = 'todos';

  function filtrar() {
    const busqueda = searchInput.value.toLowerCase().trim();
    let visibles = 0;

    items.forEach((item) => {
      const modelo = item.dataset.modelo ?? '';
      const para   = item.dataset.para   ?? '';
      const coincideBusqueda = modelo.includes(busqueda);
      const coincideFiltro   = filtroActual === 'todos' || para === filtroActual;

      if (coincideBusqueda && coincideFiltro) {
        item.classList.remove('oculto');
        visibles++;
      } else {
        item.classList.add('oculto');
      }
    });

    emptyState.style.display = visibles === 0 ? 'block' : 'none';
    resultCount.textContent = visibles === items.length
      ? ''
      : `${visibles} resultado${visibles !== 1 ? 's' : ''}`;
    clearBtn.classList.toggle('visible', searchInput.value.length > 0);
  }

  searchInput.addEventListener('input', filtrar);

  clearBtn.addEventListener('click', () => {
    searchInput.value = '';
    searchInput.focus();
    filtrar();
  });

  filtros.forEach((filtro) => {
    filtro.addEventListener('click', () => {
      filtros.forEach((f) => f.classList.remove('activo'));
      filtro.classList.add('activo');
      filtroActual = filtro.dataset.filtro ?? 'todos';
      filtrar();
    });
  });

  filtrar();
</script>