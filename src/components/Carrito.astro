---
---
<div class="carrito-fab" id="carritoFab">
  🛒
  <span class="carrito-badge" id="carritoBadge">0</span>
</div>
 
<!-- Panel del carrito -->
<div class="carrito-panel" id="carritoPanel">
  <div class="panel-header">
    <span>🛒 Carrito</span>
    <button class="panel-cerrar" id="panelCerrar">✕</button>
  </div>
  <ul class="panel-lista" id="panelLista">
    <li class="panel-vacio">No hay productos aún</li>
  </ul>
  <div class="panel-total" id="panelTotal" style="display:none">
    <span>Productos:</span>
    <span id="totalPrecio">0</span>
    <div class="panel-comprar">
      <button class="btn-whatsapp" id="btnWhatsapp">
        Encargar por WhatsApp
      </button>
    </div>
  </div>
</div>
 
<style is:global>
.panel-comprar {
  padding: 0.8rem 1.2rem;
  border-top: 1px solid rgba(245,166,35,0.1);
  display: flex;
  justify-content: center;
}
 
.btn-whatsapp {
  width: fit-content;
  padding: 0.75rem 1.5rem;
  background: #25d366;
  color: white;
  border: none;
  border-radius: 8px;
  font-weight: 700;
  font-size: 0.85rem;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
}
 
.btn-whatsapp:hover {
  background: #1ebe5d;
  transform: translateY(-1px);
}
 
.carrito-fab {
  position: fixed;
  bottom: 2rem;
  right: 2rem;
  z-index: 999;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: var(--yellow, #f5a623);
  color: var(--navy, #0a1628);
  font-size: 1.4rem;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 4px 20px rgba(245,166,35,0.5);
  transition: transform 0.2s, box-shadow 0.2s;
}
 
.carrito-fab:hover {
  transform: scale(1.1);
  box-shadow: 0 6px 28px rgba(245,166,35,0.7);
}
 
.carrito-badge {
  position: absolute;
  top: -4px;
  right: -4px;
  background: var(--navy, #0a1628);
  color: white;
  font-size: 0.65rem;
  font-weight: 700;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  display: none; /* oculto por defecto */
  align-items: center;
  justify-content: center;
  border: 2px solid white;
}
 
.carrito-badge.visible {
  display: flex;
}
 
/* ── Panel ── */
.carrito-panel {
  position: fixed;
  bottom: 5.5rem;
  right: 2rem;
  z-index: 998;
  width: 300px;
  background: var(--navy, #0a1628);
  border: 1px solid rgba(245,166,35,0.2);
  border-radius: 14px;
  box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  color: white;
  font-family: 'DM Sans', sans-serif;
  overflow: hidden;
  opacity: 0;
  transform: translateY(10px) scale(0.97);
  pointer-events: none;
  transition: opacity 0.25s ease, transform 0.25s ease;
}
 
.carrito-panel.abierto {
  opacity: 1;
  transform: translateY(0) scale(1);
  pointer-events: all;
}
 
.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1rem 1.2rem;
  background: rgba(245,166,35,0.1);
  border-bottom: 1px solid rgba(245,166,35,0.15);
  font-weight: 700;
  font-size: 0.9rem;
}
 
.panel-cerrar {
  background: none;
  border: none;
  color: rgba(255,255,255,0.5);
  cursor: pointer;
  font-size: 0.9rem;
  transition: color 0.2s;
}
.panel-cerrar:hover { color: white; }
 
/* ── Panel Lista ────────────────────────────────── */
.panel-lista {
  list-style: none;
  margin: 0;
  padding: 0.4rem;
  max-height: 280px;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: rgba(245, 166, 35, 0.3) transparent;
}

.panel-lista::-webkit-scrollbar {
  width: 3px;
}
.panel-lista::-webkit-scrollbar-track {
  background: transparent;
}
.panel-lista::-webkit-scrollbar-thumb {
  background: rgba(245, 166, 35, 0.35);
  border-radius: 99px;
}

/* ── Vacío ──────────────────────────────────────── */
.panel-vacio {
  padding: 2rem 1.5rem;
  color: rgba(255, 255, 255, 0.2);
  font-size: 0.8rem;
  text-align: center;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

/* ── Item ───────────────────────────────────────── */
.panel-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.65rem 0.85rem;
  border-radius: 8px;
  margin-bottom: 0.15rem;
  border: 1px solid transparent;
  transition:
    background 0.18s ease,
    border-color 0.18s ease,
    transform 0.12s ease;
  cursor: default;
}

.panel-item:hover {
  background: rgba(255, 255, 255, 0.045);
  border-color: rgba(255, 255, 255, 0.07);
  transform: translateX(2px);
}

.panel-item:last-child {
  margin-bottom: 0;
}

/* ── Nombre ─────────────────────────────────────── */
.panel-item-nombre {
  flex: 1;
  font-size: 0.84rem;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.82);
  letter-spacing: 0.015em;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.3;
}

/* ── Quitar ─────────────────────────────────────── */
.panel-item-quitar {
  display: grid;
  place-items: center;
  width: 22px;
  height: 22px;
  flex-shrink: 0;
  background: none;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  color: rgba(255, 255, 255, 0.2);
  cursor: pointer;
  font-size: 0.65rem;
  line-height: 1;
  transition:
    color 0.18s ease,
    border-color 0.18s ease,
    background 0.18s ease,
    transform 0.18s ease;
}

.panel-item-quitar:hover {
  color: #f87171;
  border-color: rgba(248, 113, 113, 0.45);
  background: rgba(248, 113, 113, 0.1);
  transform: scale(1.15) rotate(90deg);
}

.panel-item-quitar:active {
  transform: scale(0.92);
}
 
.panel-total {
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  padding: 0.9rem 1.2rem;
  border-top: 1px solid rgba(245,166,35,0.2);
  font-weight: 700;
  font-size: 0.9rem;
}
 
#totalPrecio { color: var(--yellow, #f5a623); }
</style>
 
<script>
  // @ts-nocheck
  var fab        = document.getElementById('carritoFab');
  var panel      = document.getElementById('carritoPanel');
  var cerrar     = document.getElementById('panelCerrar');
  var lista      = document.getElementById('panelLista');
  var badge      = document.getElementById('carritoBadge');
  var totalEl    = document.getElementById('totalPrecio');
  var panelTotal = document.getElementById('panelTotal');
  var btnWhatsapp = document.getElementById('btnWhatsapp');
 
  // ── Cargar desde localStorage al iniciar ──
  var carrito = JSON.parse(localStorage.getItem('carrito') || '[]');
 
  function guardar() {
    localStorage.setItem('carrito', JSON.stringify(carrito));
  }
 
  function renderCarrito() {
    if (carrito.length === 0) {
      lista.innerHTML = '<li class="panel-vacio">No hay productos aún</li>';
      badge.classList.remove('visible');
      panelTotal.style.display = 'none';
      return;
    }
 
    lista.innerHTML = carrito.map(function(item, i) {
      return '<li class="panel-item">' +
        '<span class="panel-item-nombre">' + item.nombre + '</span>' +
        '<button class="panel-item-quitar" data-index="' + i + '">✕</button>' +
        '</li>';
    }).join('');
 
    lista.querySelectorAll('.panel-item-quitar').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        var i = parseInt(e.target.dataset.index || '0');
        carrito.splice(i, 1);
        guardar();
        renderCarrito();
      });
    });
 
    var cantidad = carrito.length;
    totalEl.textContent = String(cantidad);
    badge.textContent = String(cantidad);
    badge.classList.add('visible');
    panelTotal.style.display = 'flex';
  }
 
  // Abrir / cerrar
  fab.addEventListener('click', function() { panel.classList.toggle('abierto'); });
  cerrar.addEventListener('click', function() { panel.classList.remove('abierto'); });
 
  // Agregar producto
  document.querySelectorAll('.btn-carrito').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var nombre = btn.dataset.nombre || 'Montacargas';
      carrito.push({ nombre: nombre });
      guardar();
      renderCarrito();
      panel.classList.add('abierto');
    });
  });
 
  // ── Botón WhatsApp ──
  if (btnWhatsapp) {
    btnWhatsapp.addEventListener('click', function() {
      if (carrito.length === 0) return;
 
      var productos = carrito
        .map(function(item, i) { return (i + 1) + '. ' + item.nombre; })
        .join('\n');
 
      var mensaje = 'Hola, me gustaría recibir mas informacion sobre como encargar los siguientes productos:\n\n' + productos;
 
      var numero = '524741036525';
      window.open('https://wa.me/' + numero + '?text=' + encodeURIComponent(mensaje), '_blank');
    });
  }
 
  // Renderizar al cargar la página
  renderCarrito();
</script>