---
import type { Montacargas } from '../interfaces/montacargas';
const respuesta = await fetch('http://localhost:4321/api/montacargas');
const montacargas: Montacargas[] = await respuesta.json();
---
<section id="mc-root" class="fondo-diagonal fondo-particulas">
  <div class="mc-header">
    <h1>Montacargas <span class="mc-acento">disponibles</span></h1>
  </div>

  <div class="mc-outer">
    <button class="mc-btn" id="btnIzq">&#8592;</button>

    <div class="mc-clip">
      <div class="mc-stage" id="mcStage">
        {montacargas.map((m, i) => (
          <div class="mc-card" data-index={String(i)}>
            <div class="mc-card-img">
              <img src={m.imagen} alt={m.modelo} />
            </div>
            <div class="mc-card-body">
              <h3>{m.modelo}</h3>
              <div class="mc-tags">
                <span class="mc-tag">⚖️ {m.capacidad}</span>
                <span class="mc-tag mc-tag-tipo">⚡ {m.tipo}</span>
              </div>
              <span class="mc-badge">{m.para}</span>
              <a href={`../${m.id}`} style="text-decoration: none;">
                <button class="mc-cta">Ver detalles →</button>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>

    <button class="mc-btn" id="btnDer">&#8594;</button>
  </div>

  <div class="mc-dots" id="mcDots">
    {montacargas.map((_, i) => (
      <button class="mc-dot" data-dot={String(i)}></button>
    ))}
  </div>

  <a href="../Catalogo/#buscar" style="text-decoration: none;">
    <button class="bttn-cat">Ver catálogo</button>
  </a>
<canvas id="sparks"></canvas>
</section>
<div class="separador-ola">
  <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#0c0c0c"/>
  </svg>
</div>
<style is:global>

 #mc-root {
    padding: 4rem 2rem !important;
    /*background: #4d4c5a !important;*/
     color: rgba(161, 53, 53, 0.408) !important; 
    font-family: 'DM Sans', 'Century Gothic', sans-serif !important;
    box-sizing: border-box !important;
    overflow: hidden !important;
    max-width: 100% !important;
    color: #0c0c0c;
  }

  #mc-root * {
    box-sizing: border-box !important;
  }

  /* ── HEADER ── */
  #mc-root .mc-header {
    text-align: center !important;
    margin-bottom: 0.5rem !important;
  }

  #mc-root .mc-header h1 {
    font-size: 3rem !important;
    font-weight: 800 !important;
    margin: 0 !important;
    color: rgb(249, 246, 246) !important;
    letter-spacing: -0.02em !important;
  }

  #mc-root .mc-acento {
    color: #8B0D1E !important;
  }

  /* ── LAYOUT ── */
  #mc-root .mc-outer {
    position: relative !important;
    width: 100% !important;
    max-width: 900px !important;
    margin: 0 auto !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }

  #mc-root .mc-clip {
    position: relative !important;
    width: 100% !important;
    height: 480px !important;
    overflow: hidden !important;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      rgb(253, 238, 238) 15%,
      rgb(249, 241, 241) 85%,
      transparent 100%
    ) !important;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      rgb(239, 229, 229) 15%,
      rgb(239, 229, 229) 85%,
      transparent 100%
    ) !important;
  }

  #mc-root .mc-stage {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    overflow: visible !important;
  }

  /* ── CARD ── */
  #mc-root .mc-card {
    position: absolute !important;
    width: 260px !important;
    top: 50% !important;
    left: 50% !important;
    transform: translate(-50%, -50%) !important;
    background: linear-gradient(145deg, #3d2020 0%, #2a1515 100%) !important;
    border: 1px solid rgba(139, 13, 30, 0.25) !important;
    border-radius: 20px !important;
    overflow: hidden !important;
    cursor: pointer !important;
    transition:
      transform 0.55s cubic-bezier(0.25,0.46,0.45,0.94),
      opacity   0.55s ease,
      box-shadow 0.55s ease !important;
  }

  #mc-root .mc-card-img {
    width: 100% !important;
    height: 150px !important;
    background: linear-gradient(135deg, #e8e0dc, #d4c8c2) !important;
    overflow: hidden !important;
  }

  #mc-root .mc-card-img img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    display: block !important;
  }

  #mc-root .mc-card-body {
    padding: 1.1rem 1.3rem 1.3rem !important;
  }

  #mc-root .mc-card-body h3 {
    font-size: 1.05rem !important;
    font-weight: 800 !important;
    margin: 0 0 0.7rem 0 !important;
    color: white !important;
  }

  /* ── TAGS ── */
  #mc-root .mc-tags {
    display: flex !important;
    gap: 0.4rem !important;
    flex-wrap: wrap !important;
    margin-bottom: 0.5rem !important;
  }

  #mc-root .mc-tag {
    font-size: 0.72rem !important;
    background: rgba(255,255,255,0.07) !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
    border-radius: 999px !important;
    padding: 0.2rem 0.6rem !important;
    color: rgba(255,255,255,0.75) !important;
  }

  #mc-root .mc-tag-tipo {
    color: #c2b09a !important;
    border-color: rgba(111, 79, 55, 0.4) !important;
    background: rgba(111, 79, 55, 0.12) !important;
  }

  /* ── BADGE ── */
  #mc-root .mc-badge {
    display: inline-block !important;
    font-size: 0.68rem !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.1em !important;
    color: #c2b5ac !important;
    margin-bottom: 0.7rem !important;
  }

  /* ── CTA CARD ── */
  #mc-root .mc-cta {
    width: 100% !important;
    background: #8B0D1E !important;
    border: none !important;
    border-radius: 10px !important;
    color: #ffffff !important;
    font-size: 0.82rem !important;
    font-weight: 800 !important;
    padding: 0.55rem 1rem !important;
    cursor: pointer !important;
    display: block !important;
    transition: background 0.2s ease, transform 0.15s ease !important;
  }

  #mc-root .mc-cta:hover {
    background: #a50f23 !important;
    transform: translateY(-1px) !important;
  }

  /* ── BOTONES NAV ── */
  #mc-root .mc-btn {
    position: absolute !important;
    top: 50% !important;
    transform: translateY(-50%) !important;
    background: rgba(139, 13, 30, 0.12) !important;
    border: 1px solid rgba(139, 13, 30, 0.3) !important;
    color: white !important;
    font-size: 1.1rem !important;
    width: 46px !important;
    height: 46px !important;
    border-radius: 50% !important;
    cursor: pointer !important;
    z-index: 30 !important;
    transition: background 0.2s, border-color 0.2s, color 0.2s !important;
  }

  #mc-root .mc-btn:hover {
    background: rgba(139, 13, 30, 0.35) !important;
    border-color: rgba(139, 13, 30, 0.7) !important;
    color: #ffffff !important;
  }

  #mc-root #btnIzq {
    left: 8px !important;
  }

  #mc-root #btnDer {
    right: 8px !important;
  }

  /* ── DOTS ── */
  #mc-root .mc-dots {
    display: flex !important;
    justify-content: center !important;
    gap: 0.5rem !important;
  }

  #mc-root .mc-dot {
    width: 8px !important;
    height: 8px !important;
    border-radius: 50% !important;
    border: none !important;
    background: rgba(255,255,255,0.15) !important;
    cursor: pointer !important;
    padding: 0 !important;
    transition: background 0.3s, width 0.3s !important;
  }

  #mc-root .mc-dot.activo {
    background: #8B0D1E !important;
    width: 24px !important;
    border-radius: 4px !important;
  }

  /* ── BOTÓN CATÁLOGO ── */
  .bttn-cat {
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
    margin: 1.5rem auto 0 auto !important;
    background: #8B0D1E !important;
    height: 44px !important;
    width: 160px !important;
    border-radius: 8px !important;
    border: 2px solid rgba(139, 13, 30, 0.5) !important;
    text-decoration: none !important;
    color: white !important;
    font-weight: 700 !important;
    font-size: 0.9rem !important;
    letter-spacing: 0.05em !important;
    text-transform: uppercase !important;
    box-shadow: 0 4px 15px rgba(139, 13, 30, 0.35) !important;
    transition: all 0.25s ease !important;
    cursor: pointer !important;
  }

  .bttn-cat:hover {
    background: #a50f23 !important;
    box-shadow: 0 6px 20px rgba(139, 13, 30, 0.55) !important;
    transform: translateY(-2px) !important;
  }
