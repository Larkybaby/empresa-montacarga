---
// HeroVideo.astro
// Cambia estos valores:
const titulo = "Soluciones en Montacargas";
const subtitulo = "Potencia, precisión y confiabilidad para tu operación industrial.";
---

<section class="hero">
  <!-- Video de fondo -->
  <video autoplay muted loop playsinline class="background-video">
    <source src="/videos/Montacargaloop1.mp4" type="video/mp4">
  </video>

  <!-- Capas de efecto -->
  <div class="overlay"></div>
  <div class="gradient-bottom"></div>
  <div class="gradient-top"></div>
  <div class="noise"></div>

  <!-- Líneas industriales decorativas -->
  <div class="grid-lines">
    <span></span><span></span><span></span><span></span>
  </div>

  <!-- Contenido -->
  <div class="hero-content">
    <div class="eyebrow">
      <span class="dot"></span>
      <p>Operando desde </p>
    </div>
    <h1 class="titulo">{titulo}</h1>
    <p class="subtitulo">{subtitulo}</p>
    <div class="botones">
      <a href="/Catalogo" class="boton boton--primary">
        <span class="boton__text">Ver Catálogo</span>
        <span class="boton__icon">→</span>
      </a>
      <a href="/Contacto" class="boton boton--secondary">
        <span class="boton__text">Contáctanos</span>
        <span class="boton__icon">✦</span>
      </a>
    </div>
    <div class="divider"></div>
  </div>

  <!-- Indicador scroll -->
  <div class="scroll-indicator">
    <span>SCROLL</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;600;800&family=Barlow:wght@300;400&display=swap');

  :root {
    --rojo: #8B0D1E;
    --cafe: #6F4F37;
    --carbon: #454545;
    --blanco: #F0EDE8;
    --negro: #0A0A0A;
  }

  .hero {
    position: relative;
    width: 100%;
    height: 70vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    font-family: 'Barlow', sans-serif;
    background: var(--negro);
  }

  /* ── VIDEO ── */
  .background-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.08);
    transition: transform 0.1s linear;
    will-change: transform;
  }

  /* ── OVERLAYS ── */
  .overlay {
    position: absolute;
    inset: 0;
    background: rgba(8, 8, 8, 0.62);
    z-index: 1;
  }

  .gradient-bottom {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 45%;
    background: linear-gradient(to top, #0A0A0A 0%, transparent 100%);
    z-index: 2;
  }

  .gradient-top {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 25%;
    background: linear-gradient(to bottom, rgba(0,0,0,0.5) 0%, transparent 100%);
    z-index: 2;
  }

  /* Textura grain */
  .noise {
    position: absolute;
    inset: 0;
    z-index: 3;
    opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px 180px;
    pointer-events: none;
  }

  /* ── LÍNEAS GRID INDUSTRIALES ── */
  .grid-lines {
    position: absolute;
    inset: 0;
    z-index: 4;
    display: flex;
    justify-content: space-between;
    padding: 0 8%;
    pointer-events: none;
  }

  .grid-lines span {
    display: block;
    width: 1px;
    height: 100%;
    background: linear-gradient(to bottom, transparent, rgba(139, 13, 30, 0.15), transparent);
    animation: fadeInLine 1.5s ease forwards;
    opacity: 0;
  }

  .grid-lines span:nth-child(1) { animation-delay: 0.2s; }
  .grid-lines span:nth-child(2) { animation-delay: 0.4s; }
  .grid-lines span:nth-child(3) { animation-delay: 0.6s; }
  .grid-lines span:nth-child(4) { animation-delay: 0.8s; }

  @keyframes fadeInLine {
    to { opacity: 1; }
  }

  /* ── CONTENIDO ── */
  .hero-content {
    position: relative;
    z-index: 10;
    padding: 0 8%;
    max-width: 860px;
  }

  /* Eyebrow */
  .eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-top: 2rem;
    margin-bottom: 10px;
    opacity: 0;
    transform: translateY(16px);
    animation: slideUp 0.7s ease 0.3s forwards;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #c83c4f;
    box-shadow: 0 0 10px #c83c4f;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 6px var(--rojo); }
    50%       { box-shadow: 0 0 18px var(--rojo); }
  }

  .eyebrow p {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #c83c4f;
    margin: 0;
  }

  /* Título */
  .titulo {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(3rem, 7vw, 6.5rem);
    font-weight: 800;
    line-height: 0.95;
    text-transform: uppercase;
    color: var(--negro);
    margin: 0 0 20px;
    letter-spacing: -0.01em;
    opacity: 0;
    transform: translateY(24px);
    animation: slideUp 0.8s ease 0.55s forwards;
  }

  /* Subtítulo */
  .subtitulo {
    font-family: 'Barlow', sans-serif;
    font-size: clamp(0.95rem, 1.5vw, 1.15rem);
    font-weight: 300;
    color: rgba(240, 237, 232, 0.401);
    max-width: 480px;
    line-height: 1.6;
    margin: 0 0 32px;
    opacity: 0;
    transform: translateY(20px);
    animation: slideUp 0.8s ease 0.8s forwards;
  }

  /* ── BOTONES ── */
  .botones {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 32px;
    opacity: 0;
    transform: translateY(20px);
    animation: slideUp 0.8s ease 1s forwards;
  }

  .boton {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.9rem 1.8rem;
    border: 2px solid transparent;
    border-radius: 8px;
    cursor: pointer;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    transition:
      transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.2s ease,
      background 0.2s ease,
      border-color 0.2s ease;
  }

  /* Shimmer sweep */
  .boton::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 40%,
      rgba(255, 255, 255, 0.14) 50%,
      transparent 60%
    );
    transform: translateX(-100%);
    transition: transform 0.55s ease;
    z-index: 1;
    pointer-events: none;
  }

  .boton:hover::after {
    transform: translateX(100%);
  }

  .boton__text,
  .boton__icon {
    position: relative;
    z-index: 2;
  }

  .boton__icon {
    font-size: 1rem;
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .boton:hover .boton__icon {
    transform: translateX(4px) scale(1.15);
  }

  /* Variante principal — rojo sólido */
  .boton--primary {
    background: var(--rojo);
    color: #FFFFFF;
    border-color: var(--rojo);
    box-shadow: 0 2px 0 rgba(0,0,0,0.3), 0 4px 20px rgba(139,13,30,0.35);
  }

  .boton--primary:hover {
    background: #a50f23;
    border-color: #a50f23;
    transform: translateY(-3px);
    box-shadow: 0 2px 0 rgba(0,0,0,0.2), 0 10px 32px rgba(139,13,30,0.5);
  }

  .boton--primary:active {
    transform: translateY(0px);
    box-shadow: 0 1px 0 rgba(0,0,0,0.2);
  }

  /* Variante secundaria — outlined café */
  .boton--secondary {
    background: transparent;
    color: var(--blanco);
    border-color: rgba(111, 79, 55, 0.6);
    box-shadow: none;
  }

  .boton--secondary:hover {
    background: rgba(111, 79, 55, 0.2);
    border-color: var(--cafe);
    color: #FFFFFF;
    transform: translateY(-3px);
    box-shadow: 0 10px 32px rgba(111,79,55,0.2);
  }

  .boton--secondary:active {
    transform: translateY(0px);
  }

  /* Divider */
  .divider {
    width: 0;
    height: 2px;
    background: linear-gradient(to right, var(--rojo), var(--cafe), transparent);
    animation: expandWidth 1s ease 1.3s forwards;
  }

  @keyframes expandWidth {
    to { width: 140px; }
  }

  /* ── ANIMACIONES ── */
  @keyframes slideUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── SCROLL INDICATOR ── */
  .scroll-indicator {
    position: absolute;
    bottom: 32px;
    right: 8%;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0;
    animation: fadeIn 1s ease 1.6s forwards;
  }

  .scroll-indicator span {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: rgba(240, 237, 232, 0.4);
    writing-mode: vertical-rl;
  }

  .scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, rgba(139,13,30,0.7), transparent);
    animation: scrollPulse 2s ease-in-out infinite 1.8s;
  }

  @keyframes scrollPulse {
    0%   { transform: scaleY(0); transform-origin: top; opacity: 1; }
    50%  { transform: scaleY(1); transform-origin: top; opacity: 1; }
    100% { transform: scaleY(1); transform-origin: top; opacity: 0; }
  }

  @keyframes fadeIn {
    to { opacity: 1; }
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .hero {
      height: 85vh;
      align-items: flex-end;
      padding-bottom: 5%;
    }

    .hero-content {
      padding: 0 6%;
    }

    .titulo {
      font-size: clamp(2.6rem, 11vw, 4rem);
    }

    .botones {
      flex-direction: column;
    }

    .boton {
      width: 100%;
      justify-content: center;
    }

    .scroll-indicator {
      display: none;
    }
  }
</style>

<script>
  const video = document.querySelector('.background-video') as HTMLVideoElement;

  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    const hero = document.querySelector('.hero') as HTMLElement;
    const heroHeight = hero?.offsetHeight ?? 0;

    if (scrollY < heroHeight) {
      const progress = scrollY / heroHeight;
      const translateY = progress * 60;
      const scale = 1.08 + progress * 0.04;
      video.style.transform = `scale(${scale}) translateY(${translateY}px)`;
    }
  }, { passive: true });
</script>