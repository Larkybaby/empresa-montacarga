---
import Conocenos from '../components/Conocenos.astro';
---

<!-- HERO -->
<section class="hero" id="about-hero">
  <div class="hero__parallax" id="hero-parallax"
       style="background-image:url('/Imagenes/About-us.jpeg')"></div>
  <div class="hero__overlay"></div>
  <div class="hero__grain" aria-hidden="true"></div>

  <div class="hero__inner">
    <div class="hero__meta reveal">
      <span class="hero__line"></span>
      <span class="hero__meta-text">Sobre la empresa</span>
      <span class="hero__line"></span>
    </div>
    <h1 class="hero__title reveal reveal--delay1">
      Acerca de<br/>
      <em>nosotros</em>
    </h1>
    <p class="hero__sub reveal reveal--delay2">
      Líderes en logística industrial · México
    </p>
  </div>

  <div class="hero__corner-badge reveal reveal--delay3">
    <svg class="hero__corner-ring" viewBox="0 0 100 100">
      <circle cx="50" cy="50" r="45" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="4 6"/>
    </svg>
    <span class="hero__corner-text">Scroll<br/>↓</span>
  </div>

  <div class="hero__wave" aria-hidden="true">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none">
      <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#141010"/>
    </svg>
  </div>
</section>

<!-- QUIÉNES SOMOS -->
<section class="qs">
  <div class="qs__inner">

    <div class="qs__visual reveal-left">
      <div class="qs__img-outer">
        <div class="qs__img-track"></div>
        <div class="qs__img-wrap">
          <img
            src="https://media.istockphoto.com/id/1916729901/es/foto/%C3%A9xito-de-la-reuni%C3%B3n-dos-personas-de-negocios-d%C3%A1ndose-la-mano-de-pie-afuera.jpg?s=612x612&w=0&k=20&c=j9CZRDV77eq-_YZL4vRcE3BiB2DZd_3tNM9eO5YAIyE="
            alt="Quiénes somos" class="qs__img"
          />
          <div class="qs__img-shine"></div>
        </div>
        <div class="qs__float-card">
          <span class="qs__float-num">10<sup>+</sup></span>
          <span class="qs__float-label">Años de<br/>experiencia</span>
        </div>
      </div>
      <div class="qs__dots" aria-hidden="true">
        <svg viewBox="0 0 120 120">
          <pattern id="dot-pat" x="0" y="0" width="15" height="15" patternUnits="userSpaceOnUse">
            <circle cx="2" cy="2" r="1.5" fill="currentColor"/>
          </pattern>
          <rect width="120" height="120" fill="url(#dot-pat)"/>
        </svg>
      </div>
    </div>

    <div class="qs__text reveal-right">
      <span class="chip">Quiénes somos</span>
      <h2 class="qs__title">
        Líderes en soluciones<br/>
        <span class="accent-text">logísticas industriales</span>
      </h2>
      <div class="slash-bar"></div>
      <p class="qs__body">
        Somos una empresa especializada en montacargas, dedicada a 
        ofrecer soluciones eficientes, seguras y confiables para el manejo y 
        traslado de carga en distintos sectores industriales.
      </p>

      <div class="qs__stats">
        <div class="qs__stat">
          <span class="qs__stat-num" data-target="500">0</span><span class="qs__stat-suffix">+</span>
          <span class="qs__stat-label">Clientes activos</span>
        </div>
        <div class="qs__stat-div"></div>
        <div class="qs__stat">
          <span class="qs__stat-num" data-target="12">0</span>
          <span class="qs__stat-label">Estados cubiertos</span>
        </div>
        <div class="qs__stat-div"></div>
        <div class="qs__stat">
          <span class="qs__stat-num" data-target="98">0</span><span class="qs__stat-suffix">%</span>
          <span class="qs__stat-label">Satisfacción</span>
        </div>
      </div>
    </div>

  </div>
</section>

<Conocenos/>

<!-- MISIÓN · VISIÓN · VALORES -->
<section class="mvv">
  <div class="mvv__bg-hex" aria-hidden="true"></div>

  <div class="mvv__header reveal">
    <span class="chip">Nuestra filosofía</span>
    <h2 class="mvv__title">Lo que nos mueve<br/><span class="accent-text">cada día</span></h2>
  </div>

  <div class="mvv__grid">

    <div class="mvv__card reveal reveal--delay1">
      <div class="mvv__card-glow"></div>
      <div class="mvv__icon">
        <svg viewBox="0 0 48 48" fill="none">
          <circle cx="24" cy="24" r="20" stroke="currentColor" stroke-width="2"/>
          <circle cx="24" cy="24" r="12" stroke="currentColor" stroke-width="2"/>
          <circle cx="24" cy="24" r="4"  fill="currentColor"/>
          <line x1="24" y1="2"  x2="24" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <line x1="24" y1="36" x2="24" y2="46" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <line x1="2"  y1="24" x2="12" y2="24" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <line x1="36" y1="24" x2="46" y2="24" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="mvv__card-num">01</div>
      <h3>Misión</h3>
      <p>Impulsar la industria con ingeniería de precisión, garantizando eficiencia y durabilidad suprema en cada pieza de acero que entregamos.</p>
      <div class="mvv__card-footer">
        <span class="mvv__card-tag">Quiénes somos</span>
      </div>
    </div>

    <div class="mvv__card mvv__card--featured reveal reveal--delay2">
      <div class="mvv__card-glow mvv__card-glow--red"></div>
      <div class="mvv__icon">
        <svg viewBox="0 0 48 48" fill="none">
          <path d="M4 24C4 24 12 10 24 10C36 10 44 24 44 24C44 24 36 38 24 38C12 38 4 24 4 24Z"
                stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
          <circle cx="24" cy="24" r="7" stroke="currentColor" stroke-width="2"/>
          <circle cx="24" cy="24" r="2.5" fill="currentColor"/>
        </svg>
      </div>
      <div class="mvv__card-num">02</div>
      <h3>Visión</h3>
      <p>Consolidarnos como el referente de excelencia en diseño industrial, donde la innovación y la maestría técnica se funden en cada proyecto.</p>
      <div class="mvv__card-footer">
        <span class="mvv__card-tag mvv__card-tag--red">Hacia el futuro</span>
      </div>
    </div>

    <div class="mvv__card reveal reveal--delay3">
      <div class="mvv__card-glow"></div>
      <div class="mvv__icon">
        <svg viewBox="0 0 48 48" fill="none">
          <path d="M24 5L28.8 17.6H42.4L31.8 25.4L35.6 38L24 30.2L12.4 38L16.2 25.4L5.6 17.6H19.2L24 5Z"
                stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="mvv__card-num">03</div>
      <h3>Valores</h3>
      <ul class="mvv__values">
        <li><span class="mvv__val-arrow">→</span>Integridad</li>
        <li><span class="mvv__val-arrow">→</span>Innovación</li>
        <li><span class="mvv__val-arrow">→</span>Compromiso</li>
        <li><span class="mvv__val-arrow">→</span>Seguridad</li>
        <li><span class="mvv__val-arrow">→</span>Excelencia</li>
      </ul>
      <div class="mvv__card-footer">
        <span class="mvv__card-tag">Nuestro ADN</span>
      </div>
    </div>

  </div>
</section>

<section class="cta">
  <div class="cta__inner_reveal">
    <h2 class="cta__title">¿Listo para trabajar junto a nosotros?</h2>
    <h1 class="cta__heading">Cuentanos sobre <br>tu proxima <em>operacion</em></h1>
    <h3 class="medio">En Sabokar nos enorgullecemos de ofrecer <br>soluciones innovadoras y de calidad para cada uno de nuestros clientes.</h3>
    <div class="cta__buttons">
      <button class="btn-cotizacion" onclick="window.location.href='/Contacto'"><h2>Solicita tu cotizacion</h2></button>
      <button onclick="window.location.href='/Catalogo'"><h2>Ver catalogo</h2></button>
    </div>
    <div class="cromada">
      <p><em class="mvv__val-arrow">→</em> RESPUESTA EN 24 HORAS</p>
      <p><em class="mvv__val-arrow">→</em> SIN COMPROMISO</p>
      <p><em class="mvv__val-arrow">→</em> ASESORIA GRATUITA</p>
    </div>
  </div>
</section>

<!-- ══ STYLES ════════════════════════════════════════════════════════════ -->
<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=Epilogue:ital,wght@0,300;0,400;0,500;1,300;1,700&display=swap');

  /* ── tokens ── */
  :root {
    /* Paleta cálida carbón — base */
    --bg-base:       #141010;   /* fondo más oscuro (body, wave) */
    --bg-section:    #1c1714;   /* secciones oscuras principales */
    --bg-card:       #2c2825;   /* tarjetas y superficies */
    --bg-card-inner: #3a2e2a;   /* interior de tarjetas anidadas */
    --bg-lifted:     #332720;   /* hover / superficies levantadas */

    /* Rojo marca */
    --red:           #8B0D1E;
    --red-mid:       #722a33;
    --red-soft:      #c8102e;
    --red-glow:      rgba(139,13,30,0.15);

    /* Textos */
    --white:         #f0ece8;   /* blanco cálido, no puro */
    --muted:         #9a8e87;   /* texto secundario */
    --faint:         rgba(240,230,220,0.28);

    /* Bordes */
    --border:        rgba(139,13,30,0.18);
    --border-hover:  rgba(139,13,30,0.45);
    --border-subtle: rgba(240,220,200,0.07);

    /* Acento (antes golden/yellow, ahora rojo cálido) */
    --accent:        #8B0D1E;
    --accent-light:  #c8102e;

    /* Legacy aliases para no romper refs existentes */
    --navy:          #141010;
    --navy2:         #1c1714;
    --navy3:         #2c2825;
    --yellow:        #8B0D1E;
    --yellow2:       #c8102e;
    --cream:         #f0ece8;
    --dark:          #0a0807;
    --ease:          cubic-bezier(.22,.8,.36,1);
    --black:         #0a0807;
    --gold-muted:    #9a7060;
    --soft-black:    #141010;
    --brand-red:     #8B0D1E;
    --brand-red-dark:#5e0912;
    --brand-red-soft:#c8102e;
    --grey:          #1c1714;
  }

  /* ── shared utilities ── */
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Epilogue', sans-serif;
    font-size: 0.67rem;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    padding: 0.3rem 0.85rem;
    border-radius: 100px;
    margin-bottom: 1.1rem;
    background: rgba(139,13,30,0.15);
    color: #e07070;
    border: 1px solid rgba(139,13,30,0.3);
  }
  .chip--red {
    background: rgba(139,13,30,0.12);
    color: #d06060;
    border: 1px solid rgba(139,13,30,0.25);
  }
  .accent-text { color: var(--red-soft); }

  .slash-bar {
    width: 48px;
    height: 4px;
    background: var(--red);
    margin-bottom: 1.4rem;
    clip-path: polygon(0 0, 100% 0, 88% 100%, 0 100%);
    border-radius: 2px;
  }
  .slash-bar--dark { background: var(--red-mid); }

  /* ── scroll reveal ── */
  .reveal, .reveal-left, .reveal-right {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.75s var(--ease), transform 0.75s var(--ease);
  }
  .reveal-left  { transform: translateX(-50px); }
  .reveal-right { transform: translateX(50px); }
  .reveal--delay1 { transition-delay: 0.12s; }
  .reveal--delay2 { transition-delay: 0.22s; }
  .reveal--delay3 { transition-delay: 0.34s; }
  .is-visible {
    opacity: 1 !important;
    transform: none !important;
  }

  /* ══ HERO ══════════════════════════════════════════════════════════════ */
  .hero {
    position: relative;
    height: 56vh;
    min-height: 420px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__parallax {
    position: absolute;
    inset: -15% 0;
    background-size: cover;
    background-position: center;
    z-index: 0;
    will-change: transform;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(120deg,
        rgba(10,8,7,0.93) 0%,
        rgba(20,16,12,0.68) 55%,
        rgba(20,16,12,0.32) 100%);
    z-index: 1;
  }

  .hero__grain {
    position: absolute;
    inset: 0;
    z-index: 2;
    opacity: 0.045;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px;
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    z-index: 3;
    padding: 0 clamp(2rem, 8vw, 9rem);
  }

  .hero__meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: 'Epilogue', sans-serif;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(240,220,200,0.38);
    margin-bottom: 0.25rem;
  }
  .hero__line {
    flex: 0 0 32px;
    height: 1px;
    background: rgba(240,200,180,0.2);
  }

  .hero__title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(3rem, 7vw, 6rem);
    font-weight: 800;
    color: var(--white);
    line-height: 1.0;
    letter-spacing: -2px;
    margin-bottom: 1rem;
    margin-top: 1.5rem;
  }
  .hero__title em {
    font-style: normal;
    color: var(--red-soft);
    position: relative;
  }
  .hero__title em::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 0; right: 0;
    height: 4px;
    background: var(--red);
    clip-path: polygon(0 0, 100% 0, 96% 100%, 4% 100%);
    opacity: 0.4;
  }

  .hero__sub {
    padding-top: 10px;
    font-family: 'Epilogue', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(240,220,200,0.32);
  }

  .hero__corner-badge {
    position: absolute;
    bottom: 3.5rem;
    right: clamp(2rem, 6vw, 5rem);
    z-index: 3;
    width: 80px; height: 80px;
    display: grid;
    place-items: center;
  }
  .hero__corner-ring {
    position: absolute;
    inset: 0;
    color: rgba(139,13,30,0.55);
    animation: spinSlow 12s linear infinite;
  }
  .hero__corner-text {
    font-family: 'Epilogue', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    color: rgba(240,220,200,0.45);
    text-align: center;
    letter-spacing: 1px;
    line-height: 1.5;
  }

  .hero__wave {
    position: absolute;
    bottom: -1px; left: 0; right: 0;
    z-index: 4;
    line-height: 0;
  }
  .hero__wave svg { width: 100%; height: 50px; }

  /* ══ QUIÉNES SOMOS ══════════════════════════════════════════════════════ */
  .qs {
    background: var(--bg-section);
    padding: clamp(5rem, 10vw, 9rem) clamp(2rem, 8vw, 9rem);
  }
  .qs__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
  }

  .qs__visual { position: relative; }
  .qs__img-outer {
    position: relative;
    padding-left: 2rem;
  }
  .qs__img-track {
    position: absolute;
    left: 0; top: 10%; bottom: 10%;
    width: 2px;
    background: linear-gradient(to bottom, transparent, var(--red), transparent);
    opacity: 0.45;
  }
  .qs__img-wrap {
    position: relative;
    overflow: hidden;
    border-radius: 14px;
    border: 1px solid var(--border);
  }
  .qs__img {
    width: 100%;
    height: 460px;
    object-fit: cover;
    display: block;
    transition: transform 0.6s var(--ease), filter 0.4s;
    filter: brightness(0.85) contrast(1.05) saturate(0.85);
  }
  .qs__img-wrap:hover .qs__img {
    transform: scale(1.04);
    filter: brightness(0.92) contrast(1.05) saturate(0.95);
  }
  .qs__img-shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(115deg, transparent 30%, rgba(255,255,255,0.1) 50%, transparent 70%);
    transform: translateX(-100%);
    transition: transform 0.7s ease;
    pointer-events: none;
  }
  .qs__img-wrap:hover .qs__img-shine { transform: translateX(100%); }

  .qs__float-card {
    position: absolute;
    bottom: -1.8rem;
    right: -1.8rem;
    background: var(--red);
    color: var(--white);
    border-radius: 14px;
    padding: 1.2rem 1.6rem;
    box-shadow: 0 12px 40px rgba(0,0,0,0.5), 0 0 0 1px rgba(139,13,30,0.4);
    text-align: center;
    z-index: 2;
  }
  .qs__float-num {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 2.2rem;
    font-weight: 800;
    line-height: 1;
    color: var(--white);
  }
  .qs__float-num sup { font-size: 1rem; vertical-align: super; }
  .qs__float-label {
    font-family: 'Epilogue', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    opacity: 0.75;
    line-height: 1.3;
    color: var(--white);
  }

  .qs__dots {
    position: absolute;
    bottom: -2rem;
    left: -1.5rem;
    width: 120px; height: 120px;
    color: rgba(139,13,30,0.18);
    z-index: 0;
  }

  .qs__title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.9rem, 3.2vw, 2.8rem);
    font-weight: 800;
    color: var(--white);
    line-height: 1.1;
    letter-spacing: -0.5px;
    margin-bottom: 0.8rem;
  }
  .qs__body {
    font-family: 'Epilogue', sans-serif;
    font-size: 1rem;
    font-weight: 300;
    color: var(--muted);
    line-height: 1.85;
    margin-bottom: 2.5rem;
  }

  .qs__stats {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-subtle);
  }
  .qs__stat { text-align: left; }
  .qs__stat-num {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--red-soft);
    line-height: 1;
  }
  .qs__stat-suffix {
    font-family: 'Syne', sans-serif;
    font-size: 1.4rem;
    color: var(--red-soft);
    vertical-align: super;
    margin-left: 1px;
  }
  .qs__stat-label {
    font-family: 'Epilogue', sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--muted);
    margin-top: 0.2rem;
    display: block;
  }
  .qs__stat-div {
    width: 1px;
    height: 48px;
    background: var(--border-subtle);
    flex-shrink: 0;
  }

  /* ══ MVV ══════════════════════════════════════════════════════════════════ */
  .mvv {
    background: var(--bg-base);
    padding: clamp(5rem, 10vw, 9rem) clamp(2rem, 8vw, 9rem);
    position: relative;
    overflow: hidden;
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  }

  .mvv__bg-hex {
    position: absolute;
    inset: 0;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg xmlns='https://www.w3.org/2000/svg' width='56' height='100'%3E%3Cpath d='M28 66L0 50V17L28 1l28 16v33z' fill='none' stroke='%23fff' stroke-width='1'/%3E%3Cpath d='M28 100L0 84V51l28-16 28 16v33z' fill='none' stroke='%23fff' stroke-width='1'/%3E%3C/svg%3E");
    background-size: 56px 100px;
    pointer-events: none;
  }

  /* warm glow behind MVV section */
  .mvv::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 40% at 50% 50%, rgba(139,13,30,0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .mvv__header {
    text-align: center;
    margin-bottom: 4rem;
    position: relative;
    z-index: 1;
  }
  .mvv__title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2.2rem, 4.5vw, 3.5rem);
    font-weight: 800;
    color: var(--white);
    line-height: 1.1;
    letter-spacing: -1px;
  }

  .mvv__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .mvv__card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 2.5rem 2rem 2rem;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s var(--ease), border-color 0.3s, box-shadow 0.3s;
    cursor: default;
  }
  .mvv__card:hover {
